// std/test.ae — Testing: assertEquals, assertTrue
// JUnit-style assertions using Aether's string interpolation and exit() built-in.

func assertEquals(actualValue: u64, expectedValue: u64, message: string) {
    if actualValue != expectedValue {
        print("  FAIL: {message} (got {actualValue}, expected {expectedValue})\n")
        exit(1)
    }
    print("  PASS: {message}\n")
}

func assertTrue(condition: bool, message: string) {
    if !condition {
        print("  FAIL: {message}\n")
        exit(1)
    }
    print("  PASS: {message}\n")
}
