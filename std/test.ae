// std/test.ae — Testing: assertEquals, assertTrue
// JUnit-style assertions. Tracks all failures in a global counter.
// The test function should return __test_failures.

import "std/io"

let mut __test_failures: u64 = 0

func assertEquals(expectedValue: u64, actualValue: u64, message: string?) {
    if actualValue != expectedValue {
        print("  FAIL: {message} (got {actualValue}, expected {expectedValue})\n")
        __test_failures += 1
    }
}

func assertDoNotEquals(expectedValue: u64, actualValue: u64, message: string?) {
    if actualValue == expectedValue {
        print("  FAIL: {message} (got {actualValue}, expected {expectedValue})\n")
        __test_failures += 1
    }
}

func assertTrue(condition: bool, message: string?) {
    if !condition {
        print("  FAIL: {message}\n")
        __test_failures += 1
    }
}
