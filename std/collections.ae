# std/collections.ae — Simple collections: Array, List
# Freestanding standard library

struct Array {
    data: u64
    length: u64
    capacity: u64
}

struct List {
    data: u64
    length: u64
    capacity: u64
}

func arrayNew(): Array {
    asm {
        xor rax, rax
        xor rdx, rdx
    }
}

func listNew(): List {
    asm {
        xor rax, rax
        xor rdx, rdx
    }
}
