# std/collections.ae — Simple collections: Array, List
# Pure Aether structs.

struct Array {
    data: u64
    length: u64
    capacity: u64
}

struct List {
    data: u64
    length: u64
    capacity: u64
}

func arrayNew(): Array {
    let result: Array
    result.data = 0
    result.length = 0
    result.capacity = 0
    return result
}

func listNew(): List {
    let result: List
    result.data = 0
    result.length = 0
    result.capacity = 0
    return result
}
