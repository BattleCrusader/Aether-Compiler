// ── Module System Edge Cases ──────────────────────────────────────────────

// Empty module
module EmptyModule {
}

// Module with only private members
module PrivateModule {
    private func hidden(): u64 {
        return 0
    }
    private const HIDDEN_CONST: u64 = 0
}

// Module with exports
module ExportModule {
    @export func init(): int {
        return 0
    }

    @export func fini() {
    }

    pub func do_work(): u64 {
        return 42
    }
}

// Module with ABI version
@module_abi(version=1)
module VersionedModule {
    pub func get_version(): u64 {
        return 1
    }
}

