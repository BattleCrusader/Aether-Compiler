// ── Visibility Edge Cases ────────────────────────────────────────────────

// Public struct with private fields
pub struct ApiStruct {
    pub exposed: u64
    private hidden: u64
}

// Public function returning private type
pub struct PublicReturnType {
    value: u64
}

pub func test_public_return(): PublicReturnType {
    let result: PublicReturnType
    result.value = 42
    return result
}

// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run all module system tests
    let mut result: u64 = 0

    result += test_file_as_module()
    result += test_source_import_syntax()
    result += test_source_import_path()
    result += test_source_import_relative()
    result += test_source_import_circular_detection()
    result += test_source_import_two_pass()
    result += test_aelib_format_magic()
    result += test_aelib_format_version()
    result += test_aelib_format_flags()
    result += test_aelib_format_abi()
    result += test_aelib_code_section()
    result += test_aelib_metadata_section()
    result += test_import_all_public()
    result += test_import_specific_class()
    result += test_import_multiple_classes()
    result += test_import_explicit_aelib()
    result += test_import_stdlib()
    result += test_resolution_ae_first()
    result += test_resolution_aelib_second()
    result += test_resolution_package_third()
    result += test_resolution_stdlib_fourth()
    result += test_resolution_error()
    result += test_pub_function()
    result += test_default_public()
    result += test_build_lib_target()
    result += test_build_lib_output()
    result += test_linking_static()
    result += test_linking_dynamic()
    result += test_linking_static_benefits()
    result += test_linking_dynamic_benefits()
    result += test_multi_arch_x86_64()
    result += test_multi_arch_arm64()
    result += test_multi_arch_riscv64()
    result += test_multi_arch_metadata()
    result += test_module_import_class()
    result += test_module_import_multiple()
    result += test_aelib_security()
    result += test_aelib_custom_disassembler()
    result += test_import_empty_file()
    result += test_import_self()
    result += test_import_nonexistent()
    result += test_import_with_spaces()
    result += test_import_deeply_nested()
    result += test_import_unicode()
    result += test_public_return().value

    return result
}
