// ── 26.9 Multi-Arch Libraries ────────────────────────────────────────────
// .aelib can contain code for multiple architectures

func test_multi_arch_x86_64(): u64 {
    // x86_64 code in .aelib
    asm {
        mov rax, 1
    }
    return 1
}

func test_multi_arch_arm64(): u64 {
    // ARM64 code in .aelib
    asm {
        mov rax, 2
    }
    return 2
}

func test_multi_arch_riscv64(): u64 {
    // RISC-V code in .aelib
    asm {
        mov rax, 3
    }
    return 3
}

func test_multi_arch_metadata(): u64 {
    // Metadata is arch-agnostic — references symbols by name
    // Linker picks the right arch at build time
    return 1
}

// ── 26.10 Class/Namespace Imports ───────────────────────────────────────
// Class-level imports avoid ambiguity

module MathLib {
    pub func add(a: u64, b: u64): u64 {
        return a + b
    }

    pub func sub(a: u64, b: u64): u64 {
        return a - b
    }

    pub func mul(a: u64, b: u64): u64 {
        return a * b
    }

    private func internal_helper(): u64 {
        return 0
    }
}

module StringLib {
    pub func concat(a: string, b: string): string {
        return a + b
    }

    pub func length(s: string): u64 {
        return 5  // simplified
    }
}

func test_module_import_class(): u64 {
    // import "lib" : MathLib — import specific class
    return MathLib::add(10, 20)
}

func test_module_import_multiple(): u64 {
    // import "lib" : MathLib, StringLib
    let sum: u64 = MathLib::add(30, 40)
    return sum
}

