// test_spec_04_classes.ae — Section 4.6: Classes
// Tests: class definition, methods, self, new/init, field access

import "std/test"

class Counter {
    value: u64

    func new(): Counter {
        let mut c: Counter
        c.value = 0
        return c
    }

    func increment() {
        self.value = self.value + 1
    }

    func add(n: u64) {
        self.value = self.value + n
    }

    func get(): u64 {
        return self.value
    }
}

class Point {
    x: i64
    y: i64

    func new(x: i64, y: i64): Point {
        let mut p: Point
        p.x = x
        p.y = y
        return p
    }

    func distance_sq(): i64 {
        return self.x * self.x + self.y * self.y
    }
}

@test
func main(): void {
    // Create and use Counter
    let mut c: Counter = Counter::new()
    let initial: u64 = c.get()  // 0

    c.increment()
    let after_inc: u64 = c.get()  // 1

    c.add(41)
    let after_add: u64 = c.get()  // 42

    // Create and use Point
    let p: Point = Point::new(3, 4)
    let dist: i64 = p.distance_sq()  // 9 + 16 = 25

    // Direct field access
    let px: i64 = p.x
    let py: i64 = p.y

    // Verify with assertions
    assertEquals(0, initial, "initial counter value should be 0")
    assertEquals(1, after_inc, "after increment should be 1")
    assertEquals(42, after_add, "after add(41) should be 42")
    assertEquals(25, dist as u64, "Point(3,4) distance_sq should be 25")
    assertEquals(3, px as u64, "p.x should be 3")
    assertEquals(4, py as u64, "p.y should be 4")
}
