// test_trycatch_finally.ae — try/catch with finally block
import "std/test"

@test
func main(): void {
    let mut result: u64 = 0
    let mut finally_ran: u64 = 0

    try {
        result = 42
    } catch Error {
        result = 0
    } finally {
        finally_ran = 1
    }

    assertEquals(42, result, "test_trycatch_finally.ae")
}
