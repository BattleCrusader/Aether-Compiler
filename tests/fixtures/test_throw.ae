// test_throw.ae — throw and catch
import "std/test"

func do_throw(): u64 throws {
    throw 99
    return 0
}

@test
func main(): void {
    let mut result: u64 = 0

    try {
        result = do_throw()
    } catch Error {
        result = 42
    }

    assertEquals(42, result, "test_throw.ae")
}
