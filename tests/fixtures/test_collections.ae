// test_collections.ae — comprehensive tests for std/collections.ae
// Tests: Array, List, HashMap, Set, Queue, Stack, Deque

import "std/test"
import "std/collections"

@test
func main() {
    // Array
    let arr: Array = newArray()
    assertEquals(arr.length, 0, "newArray length 0")
    assertEquals(arr.capacity, 0, "newArray capacity 0")

    // List
    let lst: List = newList()
    assertEquals(lst.length, 0, "newList length 0")
    assertEquals(lst.capacity, 0, "newList capacity 0")

    // HashMap
    let map: HashMap = newHashMap(16)
    assertEquals(hashMapLen(&map), 0, "newHashMap len 0")

    // put and get
    hashMapPut(&map, "one", 1)
    hashMapPut(&map, "two", 2)
    hashMapPut(&map, "three", 3)
    assertEquals(hashMapLen(&map), 3, "hashMap len after 3 puts")
    assertEquals(hashMapGet(&map, "one"), 1, "hashMap get one")
    assertEquals(hashMapGet(&map, "two"), 2, "hashMap get two")
    assertEquals(hashMapGet(&map, "three"), 3, "hashMap get three")

    // containsKey
    assertTrue(hashMapContainsKey(&map, "one"), "hashMap containsKey one")
    assertTrue(hashMapContainsKey(&map, "two"), "hashMap containsKey two")
    assertTrue(!hashMapContainsKey(&map, "four"), "hashMap containsKey four (absent)")

    // update existing key
    hashMapPut(&map, "one", 100)
    assertEquals(hashMapGet(&map, "one"), 100, "hashMap update value")
    assertEquals(hashMapLen(&map), 3, "hashMap len after update (same)")

    // remove
    hashMapRemove(&map, "two")
    assertEquals(hashMapLen(&map), 2, "hashMap len after remove")
    assertTrue(!hashMapContainsKey(&map, "two"), "hashMap containsKey after remove")
    assertEquals(hashMapGet(&map, "two"), 0, "hashMap get after remove returns 0")

    // remove non-existent key
    hashMapRemove(&map, "nonexistent")
    assertEquals(hashMapLen(&map), 2, "hashMap len after remove non-existent")

    // get non-existent key
    assertEquals(hashMapGet(&map, "nonexistent"), 0, "hashMap get non-existent returns 0")

    // Set
    let set: Set = newSet(16)
    assertEquals(setLen(&set), 0, "newSet len 0")

    setPut(&set, "apple")
    setPut(&set, "banana")
    setPut(&set, "cherry")
    assertEquals(setLen(&set), 3, "set len after 3 puts")

    assertTrue(setContains(&set, "apple"), "set contains apple")
    assertTrue(setContains(&set, "banana"), "set contains banana")
    assertTrue(!setContains(&set, "durian"), "set does not contain durian")

    // duplicate put
    setPut(&set, "apple")
    assertEquals(setLen(&set), 3, "set len after duplicate put")

    // remove
    setRemove(&set, "banana")
    assertEquals(setLen(&set), 2, "set len after remove")
    assertTrue(!setContains(&set, "banana"), "set does not contain after remove")

    // remove non-existent
    setRemove(&set, "nonexistent")
    assertEquals(setLen(&set), 2, "set len after remove non-existent")

    // Queue
    let queue: Queue = newQueue(8)
    assertTrue(queueIsEmpty(&queue), "newQueue isEmpty true")
    assertEquals(queueLen(&queue), 0, "newQueue len 0")

    queueEnqueue(&queue, 10)
    queueEnqueue(&queue, 20)
    queueEnqueue(&queue, 30)
    assertTrue(!queueIsEmpty(&queue), "queue not empty after enqueues")
    assertEquals(queueLen(&queue), 3, "queue len after 3 enqueues")

    // dequeue in FIFO order
    assertEquals(queueDequeue(&queue), 10, "queue dequeue first")
    assertEquals(queueDequeue(&queue), 20, "queue dequeue second")
    assertEquals(queueDequeue(&queue), 30, "queue dequeue third")
    assertTrue(queueIsEmpty(&queue), "queue empty after all dequeues")
    assertEquals(queueLen(&queue), 0, "queue len 0 after all dequeues")

    // dequeue from empty queue
    assertEquals(queueDequeue(&queue), 0, "queue dequeue empty returns 0")

    // wrap-around behavior
    let queue2: Queue = newQueue(4)
    queueEnqueue(&queue2, 1)
    queueEnqueue(&queue2, 2)
    queueEnqueue(&queue2, 3)
    assertEquals(queueDequeue(&queue2), 1, "queue wrap dequeue 1")
    assertEquals(queueDequeue(&queue2), 2, "queue wrap dequeue 2")
    queueEnqueue(&queue2, 4)
    queueEnqueue(&queue2, 5)
    assertEquals(queueLen(&queue2), 3, "queue wrap len 3")
    assertEquals(queueDequeue(&queue2), 3, "queue wrap dequeue 3")
    assertEquals(queueDequeue(&queue2), 4, "queue wrap dequeue 4")
    assertEquals(queueDequeue(&queue2), 5, "queue wrap dequeue 5")
    assertTrue(queueIsEmpty(&queue2), "queue wrap empty after all")

    // --- Stack (LIFO) ---

    let stack: Stack = newStack(8)
    assertTrue(stackIsEmpty(&stack), "newStack isEmpty true")
    assertEquals(stackLen(&stack), 0, "newStack len 0")

    // peek on empty stack
    assertEquals(stackPeek(&stack), 0, "stack peek empty returns 0")

    // pop on empty stack
    assertEquals(stackPop(&stack), 0, "stack pop empty returns 0")

    // push and pop
    stackPush(&stack, 10)
    stackPush(&stack, 20)
    stackPush(&stack, 30)
    assertTrue(!stackIsEmpty(&stack), "stack not empty after pushes")
    assertEquals(stackLen(&stack), 3, "stack len after 3 pushes")

    // peek
    assertEquals(stackPeek(&stack), 30, "stack peek top")

    // pop in LIFO order
    assertEquals(stackPop(&stack), 30, "stack pop first (LIFO)")
    assertEquals(stackPop(&stack), 20, "stack pop second (LIFO)")
    assertEquals(stackPop(&stack), 10, "stack pop third (LIFO)")
    assertTrue(stackIsEmpty(&stack), "stack empty after all pops")
    assertEquals(stackLen(&stack), 0, "stack len 0 after all pops")

    // push after pop
    stackPush(&stack, 100)
    assertEquals(stackPeek(&stack), 100, "stack peek after re-push")
    assertEquals(stackPop(&stack), 100, "stack pop after re-push")
    assertTrue(stackIsEmpty(&stack), "stack empty after single pop")

    // --- Deque (double-ended queue) ---

    let deque: Deque = newDeque(8)
    assertTrue(dequeIsEmpty(&deque), "newDeque isEmpty true")
    assertEquals(dequeLen(&deque), 0, "newDeque len 0")

    // pop from empty
    assertEquals(dequePopFront(&deque), 0, "deque popFront empty returns 0")
    assertEquals(dequePopBack(&deque), 0, "deque popBack empty returns 0")

    // pushBack and popFront (FIFO behavior)
    dequePushBack(&deque, 10)
    dequePushBack(&deque, 20)
    dequePushBack(&deque, 30)
    assertEquals(dequeLen(&deque), 3, "deque len after 3 pushBack")
    assertEquals(dequePopFront(&deque), 10, "deque popFront first")
    assertEquals(dequePopFront(&deque), 20, "deque popFront second")
    assertEquals(dequePopFront(&deque), 30, "deque popFront third")
    assertTrue(dequeIsEmpty(&deque), "deque empty after popFront all")

    // pushFront and popBack (LIFO behavior)
    dequePushFront(&deque, 10)
    dequePushFront(&deque, 20)
    dequePushFront(&deque, 30)
    assertEquals(dequeLen(&deque), 3, "deque len after 3 pushFront")
    assertEquals(dequePopBack(&deque), 10, "deque popBack first")
    assertEquals(dequePopBack(&deque), 20, "deque popBack second")
    assertEquals(dequePopBack(&deque), 30, "deque popBack third")
    assertTrue(dequeIsEmpty(&deque), "deque empty after popBack all")

    // mixed pushFront/pushBack
    dequePushBack(&deque, 1)
    dequePushFront(&deque, 2)
    dequePushBack(&deque, 3)
    assertEquals(dequeLen(&deque), 3, "deque len after mixed pushes")
    assertEquals(dequePopFront(&deque), 2, "deque mixed popFront first")
    assertEquals(dequePopBack(&deque), 3, "deque mixed popBack last")
    assertEquals(dequePopFront(&deque), 1, "deque mixed popFront remaining")
    assertTrue(dequeIsEmpty(&deque), "deque empty after mixed ops")

    // wrap-around behavior
    let deque2: Deque = newDeque(4)
    dequePushBack(&deque2, 1)
    dequePushBack(&deque2, 2)
    dequePushBack(&deque2, 3)
    assertEquals(dequePopFront(&deque2), 1, "deque wrap popFront 1")
    assertEquals(dequePopFront(&deque2), 2, "deque wrap popFront 2")
    dequePushBack(&deque2, 4)
    dequePushBack(&deque2, 5)
    assertEquals(dequeLen(&deque2), 3, "deque wrap len 3")
    assertEquals(dequePopFront(&deque2), 3, "deque wrap popFront 3")
    assertEquals(dequePopFront(&deque2), 4, "deque wrap popFront 4")
    assertEquals(dequePopFront(&deque2), 5, "deque wrap popFront 5")
    assertTrue(dequeIsEmpty(&deque2), "deque wrap empty after all")
}
