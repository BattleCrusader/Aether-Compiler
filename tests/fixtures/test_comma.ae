// test_comma.ae — comma-separated match patterns
func classify(value: u64): u64 {
    return match value {
        case 1, 2, 3 -> 1
        case 4, 5, 6 -> 2
        case _ -> 0
    }
}

func main(): u64 {
    let r1 = classify(1)   // 1
    let r2 = classify(2)   // 1
    let r3 = classify(3)   // 1
    let r4 = classify(4)   // 2
    let r5 = classify(5)   // 2
    let r6 = classify(6)   // 2
    let r7 = classify(99)  // 0
    return r1 + r2 + r3 + r4 + r5 + r6 + r7  // 1+1+1+2+2+2+0 = 9
}
