// test_spec_04_traits.ae — Section 4.7: Traits and Impl Blocks
// Tests: trait definition, impl for struct, method dispatch

import "std/test"

trait Drawable {
    func draw()
    func area(): u64
}

struct Circle {
    radius: u64
}

impl Drawable for Circle {
    func draw() {
        // Drawing circle
        let _ = 0
    }

    func area(): u64 {
        // Simplified: 3 * r * r (integer approximation of pi)
        return 3 * self.radius * self.radius
    }
}

struct Square {
    side: u64
}

impl Drawable for Square {
    func draw() {
        // Drawing square
        let _ = 0
    }

    func area(): u64 {
        return self.side * self.side
    }
}

@test
func main(): void {
    // Create shapes
    let mut c: Circle
    c.radius = 7

    let mut s: Square
    s.side = 5

    // Call trait methods
    let circle_area: u64 = c.area()  // 3 * 7 * 7 = 147
    let square_area: u64 = s.area()  // 5 * 5 = 25

    // Verify with assertions
    assertEquals(147, circle_area, "Circle(7) area should be 147")
    assertEquals(25, square_area, "Square(5) area should be 25")
}
