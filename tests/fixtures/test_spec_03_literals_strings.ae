// test_spec_03_literals_strings.ae — Section 3.6: String Literals
// Tests: basic strings, escape sequences, char literals

import "std/test"

@test
func main(): void {
    // Basic string literals
    let s1: string = "hello"
    let s2: string = "world"
    let s3: string = ""

    // Escape sequences
    let s_esc: string = "newline:\n tab:\t backslash:\\ quote:\" hex:\x41"
    // \x41 = 'A'

    // String concatenation
    let s_concat: string = "hello " + "world"

    // String indexing returns byte (u8)
    let s: string = "hello"
    let first_byte: u8 = s[0]   // 'h' = 0x68
    let second_byte: u8 = s[1]  // 'e' = 0x65

    // Character literals
    let ch_a: char = 'a'
    let ch_newline: char = '\n'
    let ch_tab: char = '\t'
    let ch_backslash: char = '\\'
    let ch_quote: char = '\''
    let ch_hex: char = '\x41'  // 'A'

    // Verify with assertions
    assertEquals(0x68, first_byte as u64, "s[0] should be 0x68 ('h')")
    assertEquals(0x65, second_byte as u64, "s[1] should be 0x65 ('e')")
    assertEquals(0, #s3, "empty string should have length 0")
    assertEquals(5, #s, "string 'hello' should have length 5")
    assertEquals(11, #s_concat, "'hello ' + 'world' should have length 11")
}
