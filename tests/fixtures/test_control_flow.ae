// ============================================================
// Test 21: For loop — nested loops (Section 7.3)
// ============================================================
@test(expect=0)
func test_nested_for(): u64 {
    let mut sum: u64 = 0

    for i in 0..5 {
        for j in 0..5 {
            sum = sum + 1
        }
    }

    assertEquals(25, sum, "nested for loops 5x5 = 25")
    return __test_failures
}

// ============================================================
// Test 22: For loop — nested with break inner (Section 7.3, 7.4)
// ============================================================
@test(expect=0)
func test_nested_for_break_inner(): u64 {
    let mut sum: u64 = 0

    for i in 0..5 {
        for j in 0..5 {
            if j >= 3 {
                break
            }
            sum = sum + 1
        }
    }

    // Each outer iteration: inner runs 0,1,2 = 3 times. 5 * 3 = 15
    assertEquals(15, sum, "nested for with break inner = 15")
    return __test_failures
}

// ============================================================
// Test 23: For loop — nested with continue outer (Section 7.3, 7.4)
// Note: Loop labels (Section 5.6) — break outer, continue outer
// ============================================================
@test(expect=0)
func test_nested_continue_outer(): u64 {
    let mut sum: u64 = 0

    for i in 0..5 {
        for j in 0..5 {
            if j == 2 {
                continue
            }
            sum = sum + 1
        }
    }

    // Each outer: inner runs 0,1,3,4 = 4 times. 5 * 4 = 20
    assertEquals(20, sum, "nested for with continue inner = 20")
    return __test_failures
}

// ============================================================
// Test 24: Match — integer patterns (Section 7.5)
// ============================================================
@test(expect=0)
func test_match_integer(): u64 {
    let mut result: u64 = 0

    let x: u64 = 2
    match x {
        case 1 -> result = 10
        case 2 -> result = 20
        case 3 -> result = 30
        case _ -> result = 0
    }
    assertEquals(20, result, "match integer exact")

    let y: u64 = 5
    match y {
        case 1 -> result = 10
        case 2 -> result = 20
        case _ -> result = 99
    }
    assertEquals(99, result, "match integer default")

    return __test_failures
}

// ============================================================
// Test 25: Match — range patterns (Section 7.5)
// ============================================================
@test(expect=0)
func test_match_range(): u64 {
    let mut result: u64 = 0

    let x: u64 = 3
    match x {
        case 1..5 -> result = 10
        case 6..10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(10, result, "match range 1..5 matches 3")

    let y: u64 = 7
    match y {
        case 1..5 -> result = 10
        case 6..10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(20, result, "match range 6..10 matches 7")

    let z: u64 = 0
    match z {
        case 1..5 -> result = 10
        case 6..10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(0, result, "match range default for 0")

    let w: u64 = 99
    match w {
        case 1..5 -> result = 10
        case 6..10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(0, result, "match range default for 99")

    return __test_failures
}

// ============================================================
// Test 26: Match — as expression (Section 7.5)
// ============================================================
@test(expect=0)
func test_match_expression(): u64 {
    let x: u64 = 2

    let result = match x {
        case 0 -> 42
        case 1..9 -> 100
        case _ -> 0
    }
    assertEquals(100, result, "match expression with range")

    let y: u64 = 0
    let result2 = match y {
        case 0 -> 42
        case 1..9 -> 100
        case _ -> 0
    }
    assertEquals(42, result2, "match expression exact")

    let z: u64 = 99
    let result3 = match z {
        case 0 -> 42
        case 1..9 -> 100
        case _ -> 0
    }
    assertEquals(0, result3, "match expression default")

    return __test_failures
}

// ============================================================
// Test 27: Match — multiple cases (Section 7.5)
// ============================================================
@test(expect=0)
func test_match_multi_case(): u64 {
    let mut result: u64 = 0

    let x: u64 = 0
    match x {
        case 0 -> result = 0
        case 1 -> result = 1
        case 2 -> result = 2
        case 3 -> result = 3
        case 4 -> result = 4
        case 5 -> result = 5
        case 6 -> result = 6
        case 7 -> result = 7
        case 8 -> result = 8
        case 9 -> result = 9
        case _ -> result = 99
    }
    assertEquals(0, result, "match first case")

    let y: u64 = 9
    match y {
        case 0 -> result = 0
        case 1 -> result = 1
        case 2 -> result = 2
        case 3 -> result = 3
        case 4 -> result = 4
        case 5 -> result = 5
        case 6 -> result = 6
        case 7 -> result = 7
        case 8 -> result = 8
        case 9 -> result = 9
        case _ -> result = 99
    }
    assertEquals(9, result, "match last case before default")

    let z: u64 = 42
    match z {
        case 0 -> result = 0
        case 1 -> result = 1
        case 2 -> result = 2
        case 3 -> result = 3
        case 4 -> result = 4
        case 5 -> result = 5
        case 6 -> result = 6
        case 7 -> result = 7
        case 8 -> result = 8
        case 9 -> result = 9
        case _ -> result = 99
    }
    assertEquals(99, result, "match default case")

    return __test_failures
}

// ============================================================
// Test 28: Match — range patterns with inclusive range (Section 7.5)
// ============================================================
@test(expect=0)
func test_match_range_inclusive(): u64 {
    let mut result: u64 = 0

    let x: u64 = 5
    match x {
        case 1..=5 -> result = 10
        case 6..=10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(10, result, "match inclusive range 1..=5 matches 5")

    let y: u64 = 6
    match y {
        case 1..=5 -> result = 10
        case 6..=10 -> result = 20
        case _ -> result = 0
    }
    assertEquals(20, result, "match inclusive range 6..=10 matches 6")

    return __test_failures
}

// ============================================================
// Test 29: Defer — basic (Section 7.6)
// ============================================================
let mut defer_tracker: u64 = 0

@test(expect=0)
func test_defer_basic(): u64 {
    defer_tracker = 0

    {
        defer { defer_tracker = 42 }
    }

    assertEquals(42, defer_tracker, "defer basic execution")
    return __test_failures
}

// ============================================================
// Test 30: Defer — LIFO ordering (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_lifo(): u64 {
    defer_tracker = 0

    {
        defer { defer_tracker = defer_tracker * 2 + 1 }
        defer { defer_tracker = defer_tracker * 2 + 2 }
        defer { defer_tracker = defer_tracker * 2 + 3 }
    }

    // LIFO: last defer runs first
    // defer 3: 0 * 2 + 3 = 3
    // defer 2: 3 * 2 + 2 = 8
    // defer 1: 8 * 2 + 1 = 17
    assertEquals(17, defer_tracker, "defer LIFO ordering")
    return __test_failures
}

// ============================================================
// Test 31: Defer — multiple defers in same scope (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_multiple(): u64 {
    defer_tracker = 0

    {
        defer { defer_tracker = defer_tracker + 1 }
        defer { defer_tracker = defer_tracker + 10 }
        defer { defer_tracker = defer_tracker + 100 }
    }

    // LIFO: 0+100=100, 100+10=110, 110+1=111
    assertEquals(111, defer_tracker, "defer multiple LIFO")
    return __test_failures
}

// ============================================================
// Test 32: Defer — in nested scopes (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_nested_scope(): u64 {
    defer_tracker = 0

    {
        defer { defer_tracker = defer_tracker + 1 }
        {
            defer { defer_tracker = defer_tracker + 10 }
        }
        // Inner defer already ran, now outer defer will run
    }

    // Inner defer: 0+10=10
    // Outer defer: 10+1=11
    assertEquals(11, defer_tracker, "defer nested scopes")
    return __test_failures
}

// ============================================================
// Test 33: Defer — in while loop (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_in_while(): u64 {
    defer_tracker = 0
    let mut i: u64 = 0

    while i < 3 {
        defer { defer_tracker = defer_tracker + 1 }
        i = i + 1
    }

    // Defer runs at end of each iteration: 3 times
    assertEquals(3, defer_tracker, "defer in while loop runs per iteration")
    return __test_failures
}

// ============================================================
// Test 34: Defer — in for loop (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_in_for(): u64 {
    defer_tracker = 0

    for i in 0..3 {
        defer { defer_tracker = defer_tracker + 1 }
    }

    // Defer runs at end of each iteration: 3 times
    assertEquals(3, defer_tracker, "defer in for loop runs per iteration")
    return __test_failures
}

// ============================================================
// Test 35: Defer — in try/catch (Section 7.6)
// ============================================================
@test(expect=0)
func test_defer_in_try(): u64 {
    defer_tracker = 0

    try {
        defer { defer_tracker = 42 }
    } catch _ {
        defer_tracker = 0
    }

    assertEquals(42, defer_tracker, "defer in try/catch executes")
    return __test_failures
}

// ============================================================
// Test 36: Defer — with return (Section 7.6)
// ============================================================
func defer_with_return(): u64 {
    defer_tracker = 0

    {
        defer { defer_tracker = 99 }
        return 42
    }
}

@test(expect=0)
func test_defer_with_return(): u64 {
    let result = defer_with_return()
    assertEquals(42, result, "defer with return returns correct value")
    assertEquals(99, defer_tracker, "defer with return executes before function exit")
    return __test_failures
}

// ============================================================
// Test 37: While loop — with complex condition (Section 7.2)
// ============================================================
@test(expect=0)
func test_while_complex_condition(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 10 and sum < 30 {
        sum = sum + i
        i = i + 1
    }

    // i=0: sum=0, i=1: sum=1, i=2: sum=3, i=3: sum=6, i=4: sum=10
    // i=5: sum=15, i=6: sum=21, i=7: sum=28, i=8: sum=36 >= 30, stop
    assertEquals(36, sum, "while complex condition sum")
    assertEquals(8, i, "while complex condition counter")
    return __test_failures
}

// ============================================================
// Test 38: For loop — with break in nested if (Section 7.3, 7.4)
// ============================================================
@test(expect=0)
func test_for_break_in_if(): u64 {
    let mut sum: u64 = 0

    for i in 0..100 {
        if i > 5 {
            break
        }
        if i % 2 == 0 {
            sum = sum + i
        }
    }

    // i=0: sum=0, i=1: skip, i=2: sum=2, i=3: skip, i=4: sum=6, i=5: skip, i=6: break
    assertEquals(6, sum, "for break in if sum evens 0..4 = 6")
    return __test_failures
}

