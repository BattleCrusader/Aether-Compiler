// ============================================================
// Test 18: For loop — with index (Section 7.3)
// ============================================================
@test(expect=0)
func test_for_with_index(): u64 {
    let arr = [1, 2, 3, 4, 5]
    let mut sum_values: u64 = 0
    let mut sum_indices: u64 = 0

    for i, val in arr {
        sum_values = sum_values + val
        sum_indices = sum_indices + i
    }

    assertEquals(15, sum_values, "for with index sum values = 15")
    assertEquals(10, sum_indices, "for with index sum indices = 10")
    return __test_failures
}

