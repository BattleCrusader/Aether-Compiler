// ============================================================
// Test 49: If/elif/else with comparison chains (Section 7.1)
// ============================================================
@test(expect=0)
func test_if_comparison_chains(): u64 {
    let mut result: u64 = 0
    let x: u64 = 5

    if x == 5 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(1, result, "if x == 5")

    if x != 10 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(1, result, "if x != 10")

    if x <= 5 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(1, result, "if x <= 5")

    if x >= 5 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(1, result, "if x >= 5")

    return __test_failures
}

// ============================================================
// Test 50: While loop — with continue and counter (Section 7.2)
// ============================================================
@test(expect=0)
func test_while_continue_counter(): u64 {
    let mut i: u64 = 0
    let mut even_count: u64 = 0
    let mut odd_count: u64 = 0

    while i < 10 {
        i = i + 1
        if i % 2 == 0 {
            even_count = even_count + 1
            continue
        }
        odd_count = odd_count + 1
    }

    assertEquals(5, even_count, "while continue even count = 5")
    assertEquals(5, odd_count, "while continue odd count = 5")
    return __test_failures
}

