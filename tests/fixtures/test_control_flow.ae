// test_control_flow.ae — Comprehensive tests for Section 7: Control Flow
// Covers: if/elif/else (basic, nested, as expression), while loops (basic, infinite, break/continue),
// for loops (range .., inclusive ..=, array iteration, with index), break/continue (basic, nested, labels),
// match statements (integer, string, range patterns, default _), match as expression, defer (basic, LIFO, in try/catch, in loops).
import "std/test"

// ============================================================
// Test 1: Basic if/else (Section 7.1)
// ============================================================
@test(expect=0)
func test_if_basic(): u64 {
    let x: u64 = 10
    let mut result: u64 = 0

    if x > 5 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(1, result, "if true branch")

    if x > 20 {
        result = 1
    } else {
        result = 0
    }
    assertEquals(0, result, "if false branch")

    return __test_failures
}

// ============================================================
// Test 2: If/elif/else chain (Section 7.1)
// ============================================================
@test(expect=0)
func test_if_elif_else(): u64 {
    let mut result: u64 = 0

    // Test elif taken
    let x: u64 = 10
    if x > 20 {
        result = 0
    } elif x > 5 {
        result = 1
    } else {
        result = 2
    }
    assertEquals(1, result, "elif taken")

    // Test else taken
    if x > 20 {
        result = 0
    } elif x > 15 {
        result = 1
    } else {
        result = 2
    }
    assertEquals(2, result, "else taken")

    // Test if taken
    if x > 5 {
        result = 0
    } elif x > 3 {
        result = 1
    } else {
        result = 2
    }
    assertEquals(0, result, "if taken")

    return __test_failures
}

// ============================================================
// Test 3: Multiple elif chain (Section 7.1)
// ============================================================
@test(expect=0)
func test_multi_elif(): u64 {
    let mut result: u64 = 0

    let x: u64 = 7
    if x == 1 {
        result = 1
    } elif x == 2 {
        result = 2
    } elif x == 3 {
        result = 3
    } elif x == 4 {
        result = 4
    } elif x == 5 {
        result = 5
    } elif x == 6 {
        result = 6
    } elif x == 7 {
        result = 7
    } elif x == 8 {
        result = 8
    } else {
        result = 0
    }
    assertEquals(7, result, "multi-elif picks correct branch")

    return __test_failures
}

// ============================================================
// Test 4: Nested if/else (Section 7.1)
// ============================================================
@test(expect=0)
func test_nested_if(): u64 {
    let mut result: u64 = 0

    let a: u64 = 10
    let b: u64 = 20

    if a > 5 {
        if b > 15 {
            result = 1
        } else {
            result = 0
        }
    } else {
        result = 0
    }
    assertEquals(1, result, "nested if both true")

    if a > 5 {
        if b > 25 {
            result = 1
        } else {
            result = 2
        }
    } else {
        result = 0
    }
    assertEquals(2, result, "nested if outer true, inner false")

    if a > 15 {
        if b > 15 {
            result = 1
        } else {
            result = 0
        }
    } else {
        result = 3
    }
    assertEquals(3, result, "nested if outer false")

    return __test_failures
}

// ============================================================
// Test 5: If as expression (Section 7.1)
// ============================================================
@test(expect=0)
func test_if_expression(): u64 {
    let x: u64 = 10

    let result1 = if x > 5 { 1 } else { 0 }
    assertEquals(1, result1, "if expression true")

    let result2 = if x > 20 { 1 } else { 0 }
    assertEquals(0, result2, "if expression false")

    // Nested if expressions
    let result3 = if x > 5 {
        if x > 15 { 2 } else { 1 }
    } else {
        0
    }
    assertEquals(1, result3, "nested if expression")

    return __test_failures
}

// ============================================================
// Test 6: If expression with elif (Section 7.1)
// ============================================================
@test(expect=0)
func test_if_expression_elif(): u64 {
    let x: u64 = 10

    let result = if x > 20 {
        0
    } elif x > 5 {
        1
    } else {
        2
    }
    assertEquals(1, result, "if expression with elif")

    let result2 = if x > 20 {
        0
    } elif x > 15 {
        1
    } else {
        2
    }
    assertEquals(2, result2, "if expression with else")

    return __test_failures
}

// ============================================================
// Test 7: While loop — basic (Section 7.2)
// ============================================================
@test(expect=0)
func test_while_basic(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 10 {
        sum = sum + i
        i = i + 1
    }

    assertEquals(45, sum, "while loop sum 0..9 = 45")
    assertEquals(10, i, "while loop counter = 10")
    return __test_failures
}

// ============================================================
// Test 8: While loop — zero iterations (Section 7.2)
// ============================================================
@test(expect=0)
func test_while_zero(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 0 {
        sum = sum + i
        i = i + 1
    }

    assertEquals(0, sum, "while zero iterations sum = 0")
    assertEquals(0, i, "while zero iterations counter = 0")
    return __test_failures
}

// ============================================================
// Test 9: While loop — single iteration (Section 7.2)
// ============================================================
@test(expect=0)
func test_while_single(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 1 {
        sum = sum + i
        i = i + 1
    }

    assertEquals(0, sum, "while single iteration sum = 0")
    assertEquals(1, i, "while single iteration counter = 1")
    return __test_failures
}

// ============================================================
// Test 10: While loop with break (Section 7.2, 7.4)
// ============================================================
@test(expect=0)
func test_while_break(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 100 {
        if i >= 10 {
            break
        }
        sum = sum + i
        i = i + 1
    }

    assertEquals(45, sum, "while with break sum = 45")
    return __test_failures
}

// ============================================================
// Test 11: While loop with continue (Section 7.2, 7.4)
// ============================================================
@test(expect=0)
func test_while_continue(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 10 {
        i = i + 1
        if i % 2 == 0 {
            continue
        }
        sum = sum + i
    }

    // Odd numbers: 1, 3, 5, 7, 9 = 25
    assertEquals(25, sum, "while with continue sum odds = 25")
    return __test_failures
}

// ============================================================
// Test 12: While loop with break and continue combined (Section 7.2, 7.4)
// ============================================================
@test(expect=0)
func test_while_break_continue(): u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0

    while i < 100 {
        i = i + 1
        if i > 20 {
            break
        }
        if i % 2 == 0 {
            continue
        }
        sum = sum + i
    }

    // Odd numbers 1..19 = 100
    assertEquals(100, sum, "while break+continue sum odds 1..19 = 100")
    return __test_failures
}

