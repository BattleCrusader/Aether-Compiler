// test_trycatch_catch_var.ae — catch with variable binding
import "std/test"

func do_throw(): u64 throws {
    throw 42
    return 0
}

@test
func main(): void {
    let mut result: u64 = 0

    try {
        result = do_throw()
    } catch Error(e) {
        result = e
    }

    assertEquals(42, result, "test_trycatch_catch_var.ae")
}
