// test_spec_04_structs.ae — Section 4.4: Structs
// Tests: struct definition, field access, field assignment

import "std/test"

struct Point {
    x: u64
    y: u64
}

struct Rectangle {
    width: u64
    height: u64
    label: string
}

struct Empty {}

struct Line {
    start: Point
    end: Point
}

@test
func main(): void {
    // Create struct via field assignment
    let mut p: Point
    p.x = 10
    p.y = 20

    // Field access
    let px: u64 = p.x
    let py: u64 = p.y

    // Mutate field
    p.x = 30
    let px2: u64 = p.x

    // Struct with string field
    let mut r: Rectangle
    r.width = 100
    r.height = 200
    r.label = "box"

    // Empty struct
    let e: Empty

    // Nested structs
    let mut line: Line
    line.start.x = 0
    line.start.y = 0
    line.end.x = 10
    line.end.y = 20

    let line_len_x: u64 = line.end.x - line.start.x  // 10
    let line_len_y: u64 = line.end.y - line.start.y  // 20

    // Verify with assertions
    assertEquals(10, px, "p.x should be 10")
    assertEquals(20, py, "p.y should be 20")
    assertEquals(30, px2, "p.x after mutation should be 30")
    assertEquals(100, r.width, "r.width should be 100")
    assertEquals(200, r.height, "r.height should be 200")
    assertEquals(10, line_len_x, "line.end.x - line.start.x should be 10")
    assertEquals(20, line_len_y, "line.end.y - line.start.y should be 20")
}
