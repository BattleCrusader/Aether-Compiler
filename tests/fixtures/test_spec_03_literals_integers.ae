// test_spec_03_literals_integers.ae — Section 3.6: Integer Literals
// Tests: decimal, hex, octal, binary, digit separators, all bases with separators

@test(expect=42)
func main(): u64 {
    // Decimal literals
    let dec: u64 = 42
    let dec_large: u64 = 1000000

    // Hexadecimal literals
    let hex: u64 = 0xFF       // 255
    let hex_lower: u64 = 0xff  // 255
    let hex_zero: u64 = 0x0    // 0

    // Octal literals
    let oct: u64 = 0o77       // 63
    let oct_zero: u64 = 0o0    // 0
    let oct_10: u64 = 0o10    // 8

    // Binary literals
    let bin: u64 = 0b1010     // 10
    let bin_zero: u64 = 0b0   // 0
    let bin_all: u64 = 0b11111111  // 255

    // Digit separators in decimal
    let sep_dec: u64 = 1_000_000
    let sep_dec2: u64 = 1_000_000_000

    // Digit separators in hex
    let sep_hex: u64 = 0xFF_FF_FF_FF  // 4294967295

    // Digit separators in octal
    let sep_oct: u64 = 0o77_77_77  // 262143

    // Digit separators in binary
    let sep_bin: u64 = 0b1010_0101  // 165

    // Multiple underscores
    let multi_sep: u64 = 1___000

    // Max values
    let max_u8: u8 = 255
    let max_u16: u16 = 65535
    let max_u32: u32 = 4294967295
    let max_u64: u64 = 18446744073709551615

    // Min/max signed
    let min_i8: i8 = -128
    let max_i8: i8 = 127
    let min_i16: i16 = -32768
    let max_i16: i16 = 32767

    // Verify
    let mut score: u64 = 0
    if dec == 42 { score = score + 1 }
    if hex == 255 { score = score + 1 }
    if oct == 63 { score = score + 1 }
    if bin == 10 { score = score + 1 }
    if sep_dec == 1000000 { score = score + 1 }
    if sep_hex == 0xFFFFFFFF { score = score + 1 }
    if sep_bin == 0b10100101 { score = score + 1 }
    if max_u8 == 255 { score = score + 1 }
    if max_u16 == 65535 { score = score + 1 }

    return 42
}
