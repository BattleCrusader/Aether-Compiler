// ── 18.7 Memory Layout Directives ─────────────────────────────────────────
// @layout for flat binary layout: start address, max size, output file.

@layout(start=0x7C00, max=512, file="stage1.bin")
func stage1_mbr() {
    asm {
        ; 512-byte MBR boot sector
        xor ax, ax
        mov ds, ax
        mov es, ax
        mov ss, ax
        mov sp, 0x7C00
        ; Boot message
        mov si, boot_msg
        call print_string
        ; Load stage2 from disk
        mov ah, 0x02
        mov al, 1
        mov ch, 0
        mov cl, 2
        mov dh, 0
        mov bx, 0x7E00
        int 0x13
        ; Jump to stage2
        jmp 0x7E00
    print_string:
        lodsb
        or al, al
        jz .done
        mov ah, 0x0E
        int 0x10
        jmp print_string
    .done:
        ret
    boot_msg: db "Aether OS Stage1", 0
    times 510-($-$$) db 0
    dw 0xAA55
    }
}

// ── 18.7 Kernel Layout Verification ───────────────────────────────────────
// @kernel_layout enables kernel memory map overlap verification.

@kernel_layout
func init_memory() {
    // Compiler knows the memory map and verifies no overlap
    // 0x1000-0x1FFF: bitmap
    // 0x4000-0x4FFF: module registry
    // 0x5000-0x5FFF: syscall page
    // 0x6000-0xAFFF: page tables
    asm {
        ; Initialize memory bitmap
        mov rdi, 0x1000
        mov rcx, 0x1000
        xor al, al
        rep stosb
    }
}

