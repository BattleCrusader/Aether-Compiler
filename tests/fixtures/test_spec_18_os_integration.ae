// ── 18.9 Protocol Generation ──────────────────────────────────────────────
// protocol declarations for hardware interface definitions.

protocol Serial {
    port base = 0x3F8
    speed = 115200

    func putc(c: byte) {
        asm { mov dx, port; mov al, c; out dx, al }
    }
}

protocol GPIO {
    port base = 0x60
    direction = 0x00

    func set_pin(pin: byte, value: byte) {
        asm {
            mov dx, port
            in al, dx
            mov cl, pin
            cmp value, 1
            je .set
            and al, cl
            not cl
            and al, cl
            jmp .done
        .set:
            or al, cl
        .done:
            out dx, al
        }
    }
}

func test_protocol_declaration(): u64 {
    // Protocol declarations should compile
    return 1
}

// ── Memory-Mapped I/O ─────────────────────────────────────────────────────
// Memory-mapped I/O via unsafe pointer dereference.

const FRAMEBUFFER_ADDR = 0xA0000
const KEYBOARD_STATUS = 0x64
const KEYBOARD_DATA = 0x60

func test_mmio_read(addr: ptr u64): u64 {
    unsafe {
        return *addr
    }
}

func test_mmio_write(addr: ptr u64, value: u64) {
    unsafe {
        *addr = value
    }
}

func test_framebuffer_write(x: u64, y: u64, color: byte) {
    let offset: u64 = y * 320 + x
    let fb_addr: ptr byte = (FRAMEBUFFER_ADDR + offset) as ptr byte
    unsafe {
        *fb_addr = color
    }
}

// ── Interrupt Handling ────────────────────────────────────────────────────
// Interrupt handler setup via inline assembly.

const PIC1_COMMAND = 0x20
const PIC1_DATA = 0x21
const PIC2_COMMAND = 0xA0
const PIC2_DATA = 0xA1

func test_interrupt_setup() {
    // Remap PIC
    asm {
        mov dx, PIC1_COMMAND
        mov al, 0x11
        out dx, al
        mov dx, PIC2_COMMAND
        mov al, 0x11
        out dx, al
        mov dx, PIC1_DATA
        mov al, 0x20
        out dx, al
        mov dx, PIC2_DATA
        mov al, 0x28
        out dx, al
        mov dx, PIC1_DATA
        mov al, 0x04
        out dx, al
        mov dx, PIC2_DATA
        mov al, 0x02
        out dx, al
        mov dx, PIC1_DATA
        mov al, 0x01
        out dx, al
        mov dx, PIC2_DATA
        mov al, 0x01
        out dx, al
    }
}

func test_enable_interrupts() {
    asm {
        sti
    }
}

func test_disable_interrupts() {
    asm {
        cli
    }
}

// ── Serial Port I/O ────────────────────────────────────────────────────────
// Serial port communication via port I/O.

const COM1 = 0x3F8
const COM2 = 0x2F8
const COM3 = 0x3E8
const COM4 = 0x2E8

const LSR = 5
const LSR_THR_EMPTY = 0x20

func test_serial_init() {
    // Initialize COM1 serial port
    asm {
        mov dx, COM1
        add dx, 1
        mov al, 0x00
        out dx, al
        mov dx, COM1
        add dx, 3
        mov al, 0x80
        out dx, al
        mov dx, COM1
        mov al, 0x01
        out dx, al
        mov dx, COM1
        add dx, 1
        mov al, 0x00
        out dx, al
        mov dx, COM1
        add dx, 3
        mov al, 0x03
        out dx, al
        mov dx, COM1
        add dx, 2
        mov al, 0xC7
        out dx, al
        mov dx, COM1
        add dx, 4
        mov al, 0x0B
        out dx, al
    }
}

func test_serial_putc(c: byte) {
    // Wait for transmitter holding register empty
    asm {
        mov dx, COM1
        add dx, LSR
    .wait:
        in al, dx
        test al, LSR_THR_EMPTY
        jz .wait
        mov dx, COM1
        mov al, dil
        out dx, al
    }
}

func test_serial_puts(s: string) {
    // Write string to serial port
    let mut i: u64 = 0
    while i < 256 {
        let c: byte = s[i]
        if c == 0 { break }
        test_serial_putc(c)
        i += 1
    }
}

// ── AetherFS Filesystem Operations ────────────────────────────────────────
// Filesystem operations via syscall interface.

sys func fs_open(path: string): int at(10)
sys func fs_read(fd: int, buf: ref [u8]): int at(11)
sys func fs_write(fd: int, buf: ref [u8]): int at(12)
sys func fs_close(fd: int): int at(13)
sys func fs_seek(fd: int, offset: i64, whence: int): i64 at(14)
sys func fs_stat(fd: int): int at(15)
sys func fs_mkdir(path: string): int at(16)
sys func fs_unlink(path: string): int at(17)

func test_fs_open(): int {
    let fd: int = fs_open("/etc/aether.cfg")
    if fd >= 0 {
        fs_close(fd)
    }
    return fd
}

func test_fs_read_write(): int {
    let fd: int = fs_open("/tmp/test.txt")
    if fd < 0 { return fd }
    let buf: [u8] = [72, 101, 108, 108, 111]  // "Hello"
    let written: int = fs_write(fd, ref buf)
    fs_close(fd)
    return written
}

func test_fs_seek(): i64 {
    let fd: int = fs_open("/tmp/test.txt")
    if fd < 0 { return fd as i64 }
    let pos: i64 = fs_seek(fd, 0, 2)  // seek to end
    fs_close(fd)
    return pos
}

func test_fs_mkdir(): int {
    return fs_mkdir("/tmp/newdir")
}

func test_fs_unlink(): int {
    return fs_unlink("/tmp/test.txt")
}

// ── ELF64 Loader ──────────────────────────────────────────────────────────
// ELF64 binary loading and parsing.

const ELF_MAGIC = 0x464C457F
const ELFCLASS64 = 2
const ELFDATA2LSB = 1
const ET_EXEC = 2
const ET_DYN = 3
const PT_LOAD = 1

func test_elf_magic_check(magic: u32): bool {
    return magic == 0x464C457F
}

func test_elf_class_check(elf_class: byte): bool {
    return elf_class == 2  // ELFCLASS64
}

func test_elf_endian_check(data: byte): bool {
    return data == 1  // ELFDATA2LSB
}

func test_elf_type_check(elf_type: u16): bool {
    return elf_type == ET_EXEC or elf_type == ET_DYN
}

// ── Boot Protocol ──────────────────────────────────────────────────────────
// Boot chain protocol: stage1 → stage2 → kernel.

const STAGE1_ADDR = 0x7C00
const STAGE2_ADDR = 0x7E00
const KERNEL_ADDR = 0x100000
const STACK_ADDR = 0x7C00
const KERNEL_STACK = 0x100000

func test_boot_protocol_entry() {
    // Set up stack and jump to kernel
    asm {
        mov rsp, KERNEL_STACK
        ; Clear BSS
        extern __bss_start
        extern __bss_end
        mov rdi, __bss_start
        mov rcx, __bss_end
        sub rcx, rdi
        xor al, al
        rep stosb
        ; Jump to kernel main
        call kernel_main
    }
}

func test_boot_protocol_registers() {
    // Boot protocol register state
    asm {
        ; rdi = memory map pointer
        ; rsi = boot device
        ; rdx = kernel entry point
        ; rcx = stack top
        mov rdi, 0x1000  ; memory map at 0x1000
        mov rsi, 0x80    ; boot from first hard drive
        mov rdx, KERNEL_ADDR
        mov rcx, KERNEL_STACK
    }
}

// ── Kernel Modules (.ko format) ──────────────────────────────────────────
// Loadable kernel module interface.

const MODULE_REGISTRY = 0x4000
const MODULE_NAME_MAX = 64
const MODULE_MAX = 32

struct ModuleEntry {
    name: [byte; 64]
    init_addr: u64
    fini_addr: u64
    loaded: byte
}

func test_module_registry_init() {
    // Initialize module registry at 0x4000
    asm {
        mov rdi, MODULE_REGISTRY
        mov rcx, 0x1000
        xor al, al
        rep stosb
    }
}

func test_module_load(name: string, init: u64, fini: u64): int {
    // Find empty slot in module registry
    let mut i: u64 = 0
    while i < MODULE_MAX {
        let entry_addr: u64 = MODULE_REGISTRY + i * 80  // sizeof(ModuleEntry)
        let entry_ptr: ptr ModuleEntry = entry_addr as ptr ModuleEntry
        unsafe {
            let loaded: byte = (*entry_ptr).loaded
            if loaded == 0 {
                // Mark as loaded
                (*entry_ptr).loaded = 1
                (*entry_ptr).init_addr = init
                (*entry_ptr).fini_addr = fini
                return i as int
            }
        }
        i += 1
    }
    return -1
}

func test_module_unload(slot: int): int {
    if slot < 0 or slot >= MODULE_MAX as int {
        return -1
    }
    let entry_addr: u64 = MODULE_REGISTRY + (slot as u64) * 80
    let entry_ptr: ptr ModuleEntry = entry_addr as ptr ModuleEntry
    unsafe {
        (*entry_ptr).loaded = 0
        (*entry_ptr).init_addr = 0
        (*entry_ptr).fini_addr = 0
    }
    return 0
}

// ── Flat Binary Boot Sectors ─────────────────────────────────────────────
// Flat binary generation for boot sectors.

@layout(start=0x7C00, max=512, file="stage1.bin")
func stage1_boot() {
    asm {
        ; Stage1 boot sector
        [org 0x7C00]
        xor ax, ax
        mov ds, ax
        mov es, ax
        mov ss, ax
        mov sp, 0x7C00
        ; Print boot message
        mov si, msg
        call print
        ; Load stage2
        mov ah, 0x02
        mov al, 16
        mov ch, 0
        mov cl, 2
        mov dh, 0
        mov bx, 0x7E00
        int 0x13
        jc .error
        jmp 0x7E00
    .error:
        mov si, err_msg
        call print
        hlt
    print:
        lodsb
        or al, al
        jz .done
        mov ah, 0x0E
        int 0x10
        jmp print
    .done:
        ret
    msg: db "Aether", 0
    err_msg: db "ERR", 0
    times 510-($-$$) db 0
    dw 0xAA55
    }
}

@layout(start=0x7E00, max=16384, file="stage2.bin")
func stage2_loader() {
    asm {
        ; Stage2 loader
        [org 0x7E00]
        mov ax, 0x0003
        int 0x10
        mov si, msg
        call print
        ; Load kernel from disk
        mov ah, 0x42
        mov si, dap
        int 0x13
        jc .error
        ; Jump to kernel
        mov eax, 0x100000
        jmp eax
    .error:
        mov si, err_msg
        call print
        hlt
    print:
        lodsb
        or al, al
        jz .done
        mov ah, 0x0E
        int 0x10
        jmp print
    .done:
        ret
    msg: db "Loading kernel...", 0
    err_msg: db "Kernel load failed", 0
    dap:
        db 0x10
        db 0
        dw 64
        dw 0x0000
        dw 0x1000
        dd 2
        dd 0
    }
}

// ── Combined OS Integration Tests ─────────────────────────────────────────

func test_syscall_table_index(): u64 {
    // Verify syscall table indices match spec
    // putc=0, puts=1, open=2, read=3, write=4, close=5, exit=7
    return 7  // total syscalls defined
}

func test_kernel_mode_switch() {
    // Switch to kernel mode via syscall gate
    asm {
        ; Set up GDT for kernel mode switch
        lgdt [gdt_ptr]
        mov ax, 0x10
        mov ds, ax
        mov es, ax
        mov ss, ax
    }
}

func test_user_mode_switch() {
    // Switch to user mode
    asm {
        mov ax, 0x23
        mov ds, ax
        mov es, ax
        mov ss, ax
    }
}

// GDT for kernel mode
asm {
    section .data
gdt_start:
    dq 0x0000000000000000  ; null descriptor
gdt_code:
    dq 0x00CF9A000000FFFF  ; kernel code
gdt_data:
    dq 0x00CF92000000FFFF  ; kernel data
gdt_user_code:
    dq 0x00CFFA000000FFFF  ; user code
gdt_user_data:
    dq 0x00CFF20000FFFF    ; user data
gdt_ptr:
    dw gdt_ptr - gdt_start - 1
    dq gdt_start
    section .text
}

// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run all OS integration tests
    let result: u64 = test_freestanding_entry()
    result += test_host_compatible()
    result += test_module_interface()
    result += test_pool_declaration()
    result += test_protocol_declaration()
    result += test_syscall_table_index()
    result += test_fs_open() as u64
    result += test_fs_read_write() as u64
    result += test_fs_seek() as u64
    result += test_fs_mkdir() as u64
    result += test_fs_unlink() as u64
    result += test_elf_magic_check(0x464C457F) as u64
    result += test_elf_class_check(2) as u64
    result += test_elf_endian_check(1) as u64
    result += test_elf_type_check(2) as u64
    result += test_module_load("test", 0, 0) as u64
    result += test_module_unload(0) as u64
    return result
}
