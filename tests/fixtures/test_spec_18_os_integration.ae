// test_spec_18_os_integration.ae — Comprehensive tests for SPECIFICATION.md §18
// Aether OS Integration: sys func, syscall table, kernel mode, memory-mapped I/O,
// interrupt handling, AetherFS, serial port I/O, ELF64 loader, boot protocol,
// kernel modules (.ko), flat binary boot sectors
//
// NOTE: Uses only syntax confirmed supported by the parser/codegen.
// No struct literals (Point { x: 10 }), no void*, no tuple returns.

// ── 18.1 Freestanding Target ──────────────────────────────────────────────
// The compiler's primary target is x86_64-freestanding. No libc, no CRT.
// This test verifies that freestanding-compatible code compiles.

func test_freestanding_entry(): u64 {
    return 42
}

