// ============================================================
// Test 19: Deep recursion (Section 5.5)
// ============================================================
func deep_recursion(n: u64, target: u64): u64 {
    if n == target {
        return n
    }
    return deep_recursion(n + 1, target)
}

@test(expect=0)
func test_deep_recursion(): u64 {
    assertEquals(100, deep_recursion(0, 100), "deep recursion to 100")
    return __test_failures
}

// ============================================================
// Test 20: Recursion with multiple parameters (Section 5.5)
// ============================================================
func ackermann(m: u64, n: u64): u64 {
    if m == 0 {
        return n + 1
    }
    if n == 0 {
        return ackermann(m - 1, 1)
    }
    return ackermann(m - 1, ackermann(m, n - 1))
}

@test(expect=0)
func test_ackermann(): u64 {
    assertEquals(3, ackermann(1, 1), "ack(1,1) = 3")
    assertEquals(5, ackermann(1, 3), "ack(1,3) = 5")
    assertEquals(7, ackermann(2, 2), "ack(2,2) = 7")
    assertEquals(9, ackermann(2, 3), "ack(2,3) = 9")
    return __test_failures
}

