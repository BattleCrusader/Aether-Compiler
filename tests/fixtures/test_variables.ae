// Main test runner
// ============================================================
@test(expect=0)
func main(): u64 {
    // Run all variable tests
    let failures: u64 = 0

    failures += test_let_explicit_type()
    failures += test_let_inferred_type()
    failures += test_let_mutable()
    failures += test_const_declarations()
    failures += test_block_scope()
    failures += test_nested_block_scope()
    failures += test_shadowing()
    failures += test_multiple_shadowing()
    failures += test_global_variables()
    failures += test_global_shared()
    failures += test_recursion_factorial()
    failures += test_recursion_fibonacci()
    failures += test_mutual_recursion()
    failures += test_recursive_sum()
    failures += test_recursive_power()
    failures += test_all_primitive_types()
    failures += test_mutable_bitwise_compound()
    failures += test_global_string()
    failures += test_deep_recursion()
    failures += test_ackermann()

    print("test_variables.ae: {failures} failures total\n")
    return failures
}
