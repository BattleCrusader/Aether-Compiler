func test_all_primitive_types(): u64 {
    let a: u8 = 255
    let b: u16 = 65535
    let c: u32 = 4294967295
    let d: u64 = 18446744073709551615
    let e: i8 = -128
    let f: i16 = -32768
    let g: i32 = -2147483648
