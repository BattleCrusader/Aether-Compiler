    assertEquals(4294967295, c, "u32 max")
    assertEquals(18446744073709551615, d, "u64 max")
    assertEquals(0, __test_failures, "all primitive types declared")
    return __test_failures
}

// ============================================================
// Test 17: Mutable with compound bitwise operators (Section 5.1)
// ============================================================
@test(expect=0)
func test_mutable_bitwise_compound(): u64 {
    let mut flags: u64 = 0b1010

    flags |= 0b0101
    assertEquals(0b1111, flags, "bitwise OR compound")

    flags &= 0b1100
    assertEquals(0b1100, flags, "bitwise AND compound")

    flags ^= 0b0100
    assertEquals(0b1000, flags, "bitwise XOR compound")

    flags <<= 2
    assertEquals(0b100000, flags, "left shift compound")

    flags >>= 1
    assertEquals(0b010000, flags, "right shift compound")

    return __test_failures
}

