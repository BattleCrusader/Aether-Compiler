// ── 24.8 Capability-Based Security ────────────────────────────────────────
// Functions declare what capabilities they need.

func test_capability_io() {
    // Requires io capability
    asm {
        ; Port I/O operations
        mov dx, 0x3F8
        mov al, 0x41
        out dx, al
    }
}

func test_capability_mem() {
    // Requires mem capability
    asm {
        ; Memory operations
        mov rdi, 0x1000
        xor al, al
        mov rcx, 0x1000
        rep stosb
    }
}

func test_capability_raw() {
    // Requires raw I/O capability
    asm {
        ; Raw hardware access
        cli
        hlt
    }
}

