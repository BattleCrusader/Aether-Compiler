// ── 24.10 Compile-Time Unit Checking ─────────────────────────────────────
// The compiler tracks physical units at compile time.

func test_unit_distance(v: f64, t: f64): f64 {
    // m/s * s = m
    return v * t
}

func test_unit_speed(d: f64, t: f64): f64 {
    // m / s = m/s
    return d / t
}

func test_unit_area(w: f64, h: f64): f64 {
    // m * m = m²
    return w * h
}

// ── 24.11 Automatic Interrupt Handler Generation ──────────────────────────
// Declare interrupt handlers declaratively.

func test_interrupt_timer_handler() {
    // Timer interrupt at 0x20
    // Compiler generates:
    // 1. Correct interrupt frame save/restore
    // 2. EOI signaling
    // 3. Stack switching if needed
    asm {
        ; Save context
        push rax
        push rcx
        push rdx
        push rsi
        push rdi
        ; Handle timer tick
        ; Send EOI to PIC
        mov al, 0x20
        out 0x20, al
        ; Restore context
        pop rdi
        pop rsi
        pop rdx
        pop rcx
        pop rax
        iretq
    }
}

func test_interrupt_keyboard_handler() {
    // Keyboard interrupt at 0x21
    asm {
        push rax
        push rdx
        ; Read scancode from keyboard port
        mov dx, 0x60
        in al, dx
        ; Send EOI
        mov al, 0x20
        out 0x20, al
        pop rdx
        pop rax
        iretq
    }
}

