// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run all future features tests
    let mut result: u64 = 0

    result += test_comptime_memory_map()
    result += test_goal_io_read()
    result += test_goal_io_boot_time()
    result += test_goal_io_userspace()
    result += test_goal_io_in_memory()
    result += test_pattern_match_type()
    result += test_pattern_match_struct()
    result += test_pattern_match_enum()
    result += test_query_filter()
    result += test_query_map()
    result += test_query_sort()
    result += test_query_collect()
    result += test_query_chain()
    result += test_comptime_hardware_detect()
    result += test_error_context()
    result += test_error_context_debug()
    result += test_error_context_release()
    result += test_comptime_reflection_type_name() as u64
    result += test_comptime_reflection_size()
    result += test_comptime_reflection_align()
    result += test_comptime_constants()

    return result
}
