// test_spec_03_operators_arithmetic.ae — Section 3.4: Arithmetic Operators
// Tests: +, -, *, /, % on all integer types

import "std/test"

@test
func main(): void {
    // Addition
    let add_u64: u64 = 20 + 22
    let add_u32: u32 = 10 + 32
    let add_u16: u16 = 30 + 12
    let add_u8: u8 = 40 + 2

    // Subtraction
    let sub_u64: u64 = 50 - 8
    let sub_i64: i64 = 10 - (-32)

    // Multiplication
    let mul_u64: u64 = 6 * 7
    let mul_u32: u32 = 21 * 2

    // Division
    let div_u64: u64 = 84 / 2
    let div_u32: u32 = 126 / 3

    // Modulo
    let mod_u64: u64 = 100 % 58
    let mod_u8: u8 = 50 % 8

    // Mixed expression
    let expr: u64 = (10 + 20) * 2 - 30 / 3
    // 30 * 2 - 10 = 60 - 10 = 50

    // Negative with signed
    let neg_i64: i64 = -42
    let abs_check: i64 = if neg_i64 < 0 { -neg_i64 } else { neg_i64 }

    // All results should be 42
    assertEquals(42, add_u64, "20 + 22 should be 42")
    assertEquals(42, sub_u64, "50 - 8 should be 42")
    assertEquals(42, mul_u64, "6 * 7 should be 42")
    assertEquals(42, div_u64, "84 / 2 should be 42")
    assertEquals(42, mod_u64, "100 % 58 should be 42")
    assertEquals(50, expr, "(10+20)*2 - 30/3 should be 50")
    assertEquals(42, abs_check as u64, "abs(-42) should be 42")
}
