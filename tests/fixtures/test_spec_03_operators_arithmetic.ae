// test_spec_03_operators_arithmetic.ae — Section 3.4: Arithmetic Operators
// Tests: +, -, *, /, % on all integer types

@test(expect=42)
func main(): u64 {
    // Addition
    let add_u64: u64 = 20 + 22
    let add_u32: u32 = 10 + 32
    let add_u16: u16 = 30 + 12
    let add_u8: u8 = 40 + 2

    // Subtraction
    let sub_u64: u64 = 50 - 8
    let sub_i64: i64 = 10 - (-32)

    // Multiplication
    let mul_u64: u64 = 6 * 7
    let mul_u32: u32 = 21 * 2

    // Division
    let div_u64: u64 = 84 / 2
    let div_u32: u32 = 126 / 3

    // Modulo
    let mod_u64: u64 = 100 % 58
    let mod_u8: u8 = 50 % 8

    // Mixed expression
    let expr: u64 = (10 + 20) * 2 - 30 / 3
    // 30 * 2 - 10 = 60 - 10 = 50

    // Negative with signed
    let neg_i64: i64 = -42
    let abs_check: i64 = if neg_i64 < 0 { -neg_i64 } else { neg_i64 }

    // All results should be 42
    let check1: u64 = if add_u64 == 42 { 1 } else { 0 }
    let check2: u64 = if sub_u64 == 42 { 1 } else { 0 }
    let check3: u64 = if mul_u64 == 42 { 1 } else { 0 }
    let check4: u64 = if div_u64 == 42 { 1 } else { 0 }
    let check5: u64 = if mod_u64 == 42 { 1 } else { 0 }

    if check1 + check2 + check3 + check4 + check5 == 5 {
        return 42
    }
    return 0
}
