// test_comptime_full.ae — Comprehensive tests for Section 12: Compile-Time Execution
// Tests: #run blocks, const evaluation, const functions, compile-time assertions, metaprogramming patterns

// ============================================================
// 12.1 #run Blocks — code that executes during compilation
// ============================================================

// Basic #run block
#run {
    let x = 42
}

// #run with multiple statements
#run {
    let a = 10
    let b = 20
    let c = a + b
}

// #run with control flow
#run {
    let mut sum: u64 = 0
    let i: u64 = 0
    while i < 10 {
        sum = sum + i
        i = i + 1
    }
}

// ============================================================
// 12.2 Compile-Time Constants
// ============================================================

// Basic const declarations
const MAX_CONNECTIONS = 1000
const BUFFER_SIZE = MAX_CONNECTIONS * 64
const GREETING = "Hello, World!"

// Const with arithmetic
const TABLE_SIZE = 256
const HALF_SIZE = TABLE_SIZE / 2
const QUARTER_SIZE = TABLE_SIZE / 4
const MASK = (1 << 8) - 1

// Const with bitwise operations
const FLAG_READ = 0x01
const FLAG_WRITE = 0x02
const FLAG_EXEC = 0x04
const FLAG_ALL = FLAG_READ | FLAG_WRITE | FLAG_EXEC

// Const with multiple dependencies
const BASE = 100
const MULTIPLIER = 3
const RESULT = BASE * MULTIPLIER + 50

// Const string
const APP_NAME = "Aether"
const APP_VERSION = "1.0"
const APP_TITLE = APP_NAME + " v" + APP_VERSION

// ============================================================
// 12.3 Compile-Time Constant Evaluation in Functions
// ============================================================

func getTableSize(): u64 {
    return TABLE_SIZE
}

func getBufferSize(): u64 {
    return BUFFER_SIZE
}

func getMask(): u64 {
    return MASK
}

func getFlagsAll(): u64 {
    return FLAG_ALL
}

// ============================================================
// 12.4 Compile-Time Assertions (via #run)
// ============================================================

#run {
    // Compile-time assertion: verify constants are correct
    let assert_passed: bool = (TABLE_SIZE == 256)
    if !assert_passed {
        // This would be a compile error in a real compiler
    }
}

#run {
    // Verify arithmetic at compile time
    let check: bool = (HALF_SIZE == 128)
    if !check {
        // Compile-time assertion failed
    }
}

#run {
    // Verify bitwise operations
    let check: bool = (MASK == 255)
    if !check {
        // Compile-time assertion failed
    }
}

// ============================================================
// 12.5 Metaprogramming Patterns
// ============================================================

// Pattern: compile-time computed constants
const CACHE_LINE_SIZE = 64
const ALIGN_UP = (CACHE_LINE_SIZE - 1)
const ALIGN_MASK = ~ALIGN_UP

// Pattern: compile-time lookup tables via const
const LOOKUP_SIZE = 16
const LOOKUP_0 = 0
const LOOKUP_1 = 1
const LOOKUP_2 = 4
const LOOKUP_3 = 9
const LOOKUP_4 = 16
const LOOKUP_5 = 25
const LOOKUP_6 = 36
const LOOKUP_7 = 49
const LOOKUP_8 = 64
const LOOKUP_9 = 81
const LOOKUP_10 = 100
const LOOKUP_11 = 121
const LOOKUP_12 = 144
const LOOKUP_13 = 169
const LOOKUP_14 = 196
const LOOKUP_15 = 225

// Pattern: compile-time configuration
const CONFIG_DEBUG = true
const CONFIG_OPT_LEVEL = 2
const CONFIG_STACK_SIZE = 1024 * 1024

// Pattern: compile-time size calculations
const HEADER_SIZE = 8
const DATA_SIZE = 256
const TOTAL_SIZE = HEADER_SIZE + DATA_SIZE

// Pattern: compile-time flags
const MODE_READ = 1
const MODE_WRITE = 2
const MODE_RW = MODE_READ | MODE_WRITE

// ============================================================
// 12.6 Edge Cases
// ============================================================

// Edge case: empty #run block
#run {
}

// Edge case: #run with only comments
#run {
    // Just a comment
}

// Edge case: const with zero value
const ZERO_VALUE = 0

// Edge case: const with max values
const MAX_U8 = 255
const MAX_U16 = 65535
const MAX_U32 = 4294967295
const MAX_U64 = 18446744073709551615

// Edge case: const with negative values (via i64)
const NEG_ONE: i64 = -1
const NEG_HUNDRED: i64 = -100

// Edge case: chained const dependencies
const A = 1
const B = A + 1
const C = B + 1
const D = C + 1
const E = D + 1

// Edge case: const used in array size context
const ARRAY_SIZE = 5

// ============================================================
// Main test function
// ============================================================

@test(expect=42)
func main(): u64 {
    // Verify const values are accessible at runtime
    let t1: bool = (TABLE_SIZE == 256)
    let t2: bool = (HALF_SIZE == 128)
    let t3: bool = (MASK == 255)
    let t4: bool = (FLAG_ALL == 7)
    let t5: bool = (BUFFER_SIZE == 64000)
    let t6: bool = (ZERO_VALUE == 0)
    let t7: bool = (MAX_U8 == 255)
    let t8: bool = (E == 5)

    // Verify const functions return correct values
    let ts: u64 = getTableSize()
    let bs: u64 = getBufferSize()
    let mk: u64 = getMask()
    let fa: u64 = getFlagsAll()

    // All tests pass
    return 42
}
