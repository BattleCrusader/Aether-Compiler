// ── Architecture-Specific Data Structures ──────────────────────────────────
// Data structures that may differ per architecture.

struct ArchInfo {
    arch_id: u64
    page_size: u64
    cache_line: u64
    tlb_entries: u64
}

func test_arch_info_x86(): ArchInfo {
    let info: ArchInfo
    info.arch_id = ARCH_X86_64
    info.page_size = 4096
    info.cache_line = 64
    info.tlb_entries = 64
    return info
}

func test_arch_info_arm(): ArchInfo {
    let info: ArchInfo
    info.arch_id = ARCH_ARM64
    info.page_size = 4096
    info.cache_line = 64
    info.tlb_entries = 32
    return info
}

func test_arch_info_riscv(): ArchInfo {
    let info: ArchInfo
    info.arch_id = ARCH_RISCV64
    info.page_size = 4096
    info.cache_line = 64
    info.tlb_entries = 32
    return info
}

// ── Multi-Arch ELF Format ────────────────────────────────────────────────
// ELF structures for multi-architecture support.

const EI_NIDENT: u64 = 16
const ELFCLASS32: byte = 1
const ELFCLASS64: byte = 2
const ELFDATA2MSB: byte = 2
const EV_CURRENT: byte = 1

func test_elf_ident_check(ident: ptr byte): bool {
    unsafe {
        let class_byte: byte = (*ident + 4) as ptr byte
        let data_byte: byte = (*ident + 5) as ptr byte
        let version: byte = (*ident + 6) as ptr byte
        if class_byte != ELFCLASS64 { return false }
        if data_byte != ELFDATA2LSB { return false }
        if version != EV_CURRENT { return false }
        return true
    }
}

// ── Architecture Feature Detection ────────────────────────────────────────

func test_cpu_feature_detection(): u64 {
    let mut features: u64 = 0
    asm {
        mov rax, 1
        cpuid
        ; rcx = feature flags
        mov [features], rcx
    }
    return features
}

func test_sse_detection(): bool {
    let features: u64 = test_cpu_feature_detection()
    // SSE bit is bit 25 of ECX from CPUID leaf 1
    let sse_bit: u64 = 1 << 25
    return (features & sse_bit) != 0
}

func test_avx_detection(): bool {
    let features: u64 = test_cpu_feature_detection()
    // AVX bit is bit 28 of ECX from CPUID leaf 1
    let avx_bit: u64 = 1 << 28
    return (features & avx_bit) != 0
}

// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run universal binary tests
    let result: u64 = test_universal_concept()
    result += test_universal_target()
    result += test_universal_all_target()
    result += test_dispatch_by_arch(ARCH_X86_64)
    result += test_dispatch_by_arch(ARCH_ARM64)
    result += test_dispatch_by_arch(ARCH_RISCV64)
    result += test_cross_arch_dispatch(ARCH_X86_64)
    result += test_cross_arch_dispatch(ARCH_ARM64)
    result += test_cross_arch_dispatch(ARCH_RISCV64)
    result += test_cpu_feature_detection()
    result += test_sse_detection() as u64
    result += test_avx_detection() as u64
    return result
}
