// test_functions.ae — Comprehensive tests for Section 6: Functions
// Covers: basic declaration/calls, expression-bodied, void return, function attributes,
// default parameters, extern functions (FFI), variadic functions, calling convention.
import "std/test"

// ============================================================
// Test 1: Basic function declaration and call (Section 6.1)
// ============================================================
func add(a: u64, b: u64): u64 {
    return a + b
}

func subtract(a: u64, b: u64): u64 {
    return a - b
}

func multiply(a: u64, b: u64): u64 {
    return a * b
}

func divide(a: u64, b: u64): u64 {
    return a / b
}

@test(expect=0)
func test_basic_function_calls(): u64 {
    assertEquals(15, add(10, 5), "add(10, 5) = 15")
    assertEquals(5, subtract(10, 5), "subtract(10, 5) = 5")
    assertEquals(50, multiply(10, 5), "multiply(10, 5) = 50")
    assertEquals(2, divide(10, 5), "divide(10, 5) = 2")
    return __test_failures
}

// ============================================================
// Test 2: Expression-bodied functions (Section 6.1, -> syntax)
// ============================================================
func add_expr(a: u64, b: u64): u64 -> a + b

func multiply_expr(a: u64, b: u64): u64 -> a * b

func max_expr(a: u64, b: u64): u64 -> if a > b { a } else { b }

@test(expect=0)
func test_expression_bodied(): u64 {
    assertEquals(15, add_expr(10, 5), "add_expr(10, 5) = 15")
    assertEquals(50, multiply_expr(10, 5), "multiply_expr(10, 5) = 50")
    assertEquals(10, max_expr(10, 5), "max_expr(10, 5) = 10")
    assertEquals(20, max_expr(10, 20), "max_expr(10, 20) = 20")
    return __test_failures
}

// ============================================================
// Test 3: Void return functions (Section 6.1)
// ============================================================
let mut void_side_effect: u64 = 0

func void_func() {
    void_side_effect = 42
}

func void_func_with_param(x: u64) {
    void_side_effect = x
}

@test(expect=0)
func test_void_functions(): u64 {
    void_side_effect = 0
    void_func()
    assertEquals(42, void_side_effect, "void func sets side effect")

    void_func_with_param(99)
    assertEquals(99, void_side_effect, "void func with param sets side effect")

    return __test_failures
}

// ============================================================
// Test 4: Function with multiple parameters (Section 6.1)
// ============================================================
func sum4(a: u64, b: u64, c: u64, d: u64): u64 {
    return a + b + c + d
}

func sum6(a: u64, b: u64, c: u64, d: u64, e: u64, f: u64): u64 {
    return a + b + c + d + e + f
}

@test(expect=0)
func test_multi_param(): u64 {
    assertEquals(10, sum4(1, 2, 3, 4), "sum4(1,2,3,4) = 10")
    assertEquals(21, sum6(1, 2, 3, 4, 5, 6), "sum6(1..6) = 21")
    return __test_failures
}

// ============================================================
// Test 5: Function with no parameters (Section 6.1)
// ============================================================
func get_forty_two(): u64 {
    return 42
}

@test(expect=0)
func test_no_param(): u64 {
    assertEquals(42, get_forty_two(), "no-param function returns 42")
    return __test_failures
}

// ============================================================
// Test 6: Nested function calls (Section 6.1)
// ============================================================
func double(x: u64): u64 {
    return x * 2
}

func quadruple(x: u64): u64 {
    return double(double(x))
}

@test(expect=0)
func test_nested_calls(): u64 {
    assertEquals(40, quadruple(10), "quadruple(10) = 40")
    assertEquals(8, double(double(2)), "nested double(double(2)) = 8")
    return __test_failures
}

// ============================================================
// Test 7: Function with signed parameters (Section 6.1)
// ============================================================
func signed_add(a: i64, b: i64): i64 {
    return a + b
}

func signed_negate(x: i64): i64 {
    return -x
}

@test(expect=0)
func test_signed_params(): u64 {
    assertEquals(30, signed_add(10, 20), "signed_add(10, 20) = 30")
    assertEquals(-10, signed_add(10, -20), "signed_add(10, -20) = -10")
    assertEquals(-42, signed_negate(42), "signed_negate(42) = -42")
    assertEquals(42, signed_negate(-42), "signed_negate(-42) = 42")
    return __test_failures
}

// ============================================================
// Test 8: Function with boolean parameters (Section 6.1)
// ============================================================
func bool_to_u64(b: bool): u64 {
    if b {
        return 1
    }
    return 0
}

func logical_and(a: bool, b: bool): bool {
    return a and b
}

@test(expect=0)
func test_bool_params(): u64 {
    assertEquals(1, bool_to_u64(true), "bool_to_u64(true) = 1")
    assertEquals(0, bool_to_u64(false), "bool_to_u64(false) = 0")
    assertTrue(logical_and(true, true), "true and true = true")
    assertTrue(not logical_and(true, false), "true and false = false")
    return __test_failures
}

