    return result
}

@test(expect=0)
func test_accumulate(): u64 {
    assertEquals(15, accumulate(1, 2, 3, 4, 5), "accumulate 1..5 = 15")
    assertEquals(0, accumulate(), "accumulate empty = 0")
    return __test_failures
}

