// ============================================================
// Test 15: Default parameters (Section 6.3)
// ============================================================
func greet(name: string, greeting: string = "Hello"): string {
    return greeting + " " + name
}

func create_rect(width: u64 = 800, height: u64 = 600): u64 {
    return width * height
}

@test(expect=0)
func test_default_params(): u64 {
    // Just verify these compile and run without crash
    let msg1 = greet("World")
    let msg2 = greet("World", "Hi")
    let area1 = create_rect()
    let area2 = create_rect(1024, 768)

    assertEquals(480000, area1, "default rect area = 800*600 = 480000")
    assertEquals(786432, area2, "explicit rect area = 1024*768 = 786432")
    return __test_failures
}

// ============================================================
// Test 16: Default parameter with one required (Section 6.3)
// ============================================================
func power_default(base: u64, exp: u64 = 2): u64 {
    let mut result: u64 = 1
    let mut i: u64 = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

@test(expect=0)
func test_default_param_variants(): u64 {
    assertEquals(25, power_default(5), "5^2 = 25 (default exp)")
    assertEquals(125, power_default(5, 3), "5^3 = 125 (explicit exp)")
    assertEquals(1, power_default(5, 0), "5^0 = 1 (explicit exp=0)")
    return __test_failures
}

