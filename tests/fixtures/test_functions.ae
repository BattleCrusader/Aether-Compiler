// ============================================================
// Main test runner
// ============================================================
@test(expect=0)
func main(): u64 {
    let failures: u64 = 0

    failures += test_basic_function_calls()
    failures += test_expression_bodied()
    failures += test_void_functions()
    failures += test_multi_param()
    failures += test_no_param()
    failures += test_nested_calls()
    failures += test_signed_params()
    failures += test_bool_params()
    failures += test_inline_attribute()
    failures += test_force_inline()
    failures += test_no_inline()
    failures += test_export_attribute()
    failures += test_entry_attribute()
    failures += test_test_attribute()
    failures += test_default_params()
    failures += test_default_param_variants()
    failures += test_extern_declaration()
    failures += test_variadic_basic()
    failures += test_variadic_with_prefix()
    failures += test_variadic_many()
    failures += test_variadic_with_index()
    failures += test_variadic_types()
    failures += test_function_chaining()
    failures += test_early_returns()
    failures += test_conditional_return()
    failures += test_string_param()
    failures += test_mixed_params()
    failures += test_modulo_func()
    failures += test_bitwise_funcs()
    failures += test_shift_funcs()
    failures += test_comparison_funcs()
    failures += test_logical_funcs()
    failures += test_func_with_while()
    failures += test_func_with_for()
    failures += test_func_with_match()
    failures += test_fizzbuzz()
    failures += test_abs()
    failures += test_accumulate()
    failures += test_wrapper_variadic()
    failures += test_inline_combinations()

    print("test_functions.ae: {failures} failures total\n")
    return failures
}
