# test_fixtures.ae — comprehensive Phase 1 test
# Compile with: aether build tests/fixtures/test_fixtures.ae -o test_fixtures.elf

# Primitive types
func test_types(): int {
    let a: u8 = 200
    let b: u16 = 40000
    let c: u32 = 3000000
    let d: u64 = 50000000000
    return a + b + c + d
}

# Control flow
func test_if(x: int): int {
    if x > 0 { return 1 } elif x < 0 { return -1 }
    return 0
}

# Function calls
func add(a: int, b: int): int { return a + b }
func test_call(): int { return add(10, 20) }

# While loop
func test_while(n: int): int {
    let mut i = 0
    let mut s = 0
    while i < n { s = s + i; i = i + 1 }
    return s
}

# For loop
func test_for(): int {
    let mut s = 0
    for i in 0..10 { s = s + i }
    return s
}

# Struct
struct Point { x: int; y: int }

# Enum
enum Option { Some(int); None }

# Match
func test_match(x: int): int {
    match x {
        case 0 -> 42
        case _ -> 0
    }
}

# Bitwise
func test_bitwise(a: int, b: int): int { return a & b | a ^ b }

# Comparison
func test_cmp(a: int, b: int): bool { return a < b and b > 0 }

# Unary
func test_unary(x: int): int { return -x }

func main(): int {
    return test_types()
}