// test_mem.ae — comprehensive tests for std/mem.ae
// Tests: copyMemory, memoryCopy, zeroMemory, memcmp
// Memory management is automatic — use `heap` keyword for allocation.

import "std/test"
import "std/mem"

@test
func main() {
    // copyMemory — copy data and verify
    let src: u64 = heap 16
    let dst: u64 = heap 16
    // write some pattern to src using inline asm
    asm {
        mov rdi, [src]
        mov al, 0xAB
        mov rcx, 16
        rep stosb
    }
    // copy from src to dst
    copyMemory(dst, src, 16)
    // verify they match
    let cmpResult: i64 = memcmp(src, dst, 16)
    assertEquals(cmpResult, 0, "copyMemory: memcmp after copy equals 0")

    // memoryCopy — alias for copyMemory
    let src2: u64 = heap 16
    let dst2: u64 = heap 16
    asm {
        mov rdi, [src2]
        mov al, 0xCD
        mov rcx, 16
        rep stosb
    }
    memoryCopy(dst2, src2, 16)
    let cmpResult2: i64 = memcmp(src2, dst2, 16)
    assertEquals(cmpResult2, 0, "memoryCopy: memcmp after copy equals 0")

    // zeroMemory
    let buf: u64 = heap 16
    asm {
        mov rdi, [buf]
        mov al, 0xFF
        mov rcx, 16
        rep stosb
    }
    zeroMemory(buf, 16)
    let zeroBuf: u64 = heap 16
    // zeroBuf is already zeroed by bump allocator
    let cmpZero: i64 = memcmp(buf, zeroBuf, 16)
    assertEquals(cmpZero, 0, "zeroMemory: all bytes zeroed")

    // memcmp equal
    let a: u64 = heap 4
    let b: u64 = heap 4
    asm {
        mov rdi, [a]
        mov al, 0x01
        mov rcx, 4
        rep stosb
    }
    asm {
        mov rdi, [b]
        mov al, 0x01
        mov rcx, 4
        rep stosb
    }
    let eq: i64 = memcmp(a, b, 4)
    assertEquals(eq, 0, "memcmp equal returns 0")

    // memcmp not equal (first < second)
    let c: u64 = heap 4
    let d: u64 = heap 4
    asm {
        mov rdi, [c]
        mov al, 0x01
        mov rcx, 4
        rep stosb
    }
    asm {
        mov rdi, [d]
        mov al, 0x02
        mov rcx, 4
        rep stosb
    }
    let lt: i64 = memcmp(c, d, 4)
    assertTrue(lt < 0, "memcmp first < second returns negative")

    // memcmp not equal (first > second)
    let e: u64 = heap 4
    let f: u64 = heap 4
    asm {
        mov rdi, [e]
        mov al, 0x02
        mov rcx, 4
        rep stosb
    }
    asm {
        mov rdi, [f]
        mov al, 0x01
        mov rcx, 4
        rep stosb
    }
    let gt: i64 = memcmp(e, f, 4)
    assertTrue(gt > 0, "memcmp first > second returns positive")

    // memcmp zero bytes
    let g: u64 = heap 4
    let h: u64 = heap 4
    asm {
        mov rdi, [g]
        mov al, 0xFF
        mov rcx, 4
        rep stosb
    }
    asm {
        mov rdi, [h]
        mov al, 0xFF
        mov rcx, 4
        rep stosb
    }
    let zeroLen: i64 = memcmp(g, h, 0)
    assertEquals(zeroLen, 0, "memcmp zero bytes returns 0")
}
