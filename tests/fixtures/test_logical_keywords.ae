// test_logical_keywords.ae — test not/and/or keyword operators
// Each @test function is self-contained (no params).

import "std/test"

@test
func test_not(): void {
    let a: bool = true
    let b: bool = false
    assertTrue(not b, "not false = true")
}

@test
func test_and(): void {
    let a: bool = true
    let b: bool = false
    assertTrue(a and not b, "true and not false = true")
}

@test
func test_or(): void {
    let a: bool = true
    let b: bool = false
    assertTrue(b or a, "false or true = true")
}

@test
func test_not_on_variable(): void {
    let found: bool = false
    assertTrue(not found, "not false = true")
}
