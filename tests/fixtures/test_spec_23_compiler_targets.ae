// test_spec_23_compiler_targets.ae — Comprehensive tests for SPECIFICATION.md §23
// Compiler Targets: host, x86_64-freestanding, kernel, module, binary,
// boot, asm-x86_64, asm-arm64, asm-riscv64, universal, universal-all, wasm32
//
// NOTE: Uses only syntax confirmed supported by the parser/codegen.
// No struct literals, no void*, no tuple returns.

// ── Target: host ──────────────────────────────────────────────────────────
// Mach-O 64 / ELF64 / PE32+ — Development and testing on dev machine

func test_target_host_entry(): u64 {
    return 42
}

func test_target_host_printf() {
    // Host target can use system calls
    asm {
        ; write(1, msg, 13)
        mov rax, 0x2000004  ; macOS write syscall
        mov rdi, 1
        lea rsi, [rel .msg]
        mov rdx, 13
        syscall
        ret
    .msg:
        db "Hello, host!", 10
    }
}

func test_target_host_return(): u64 {
    let x: u64 = 100
    let y: u64 = 200
    return x + y
}

// ── Target: x86_64-freestanding ──────────────────────────────────────────
// ELF64 — Aether OS kernel (no libc, no CRT)

@entry(0x100000)
func test_target_freestanding_entry() {
    // Freestanding entry point
    asm {
        mov rsp, 0x100000
        ; Clear BSS
        extern __bss_start
        extern __bss_end
        mov rdi, __bss_start
        mov rcx, __bss_end
        sub rcx, rdi
        xor al, al
        rep stosb
    }
}

func test_target_freestanding_no_libc() {
    // No libc available — use inline assembly
    asm {
        mov rax, 42
    }
}

func test_target_freestanding_hlt() {
    asm {
        hlt
    }
}

// ── Target: kernel ────────────────────────────────────────────────────────
// ELF64 — Kernel binary with memory map verification

@kernel_layout
func test_target_kernel_layout() {
    // Compiler verifies memory map regions don't overlap
    // 0x1000-0x1FFF: bitmap
    // 0x4000-0x4FFF: module registry
    // 0x5000-0x5FFF: syscall page
    // 0x6000-0xAFFF: page tables
    asm {
        ; Initialize page tables at 0x6000
        mov rdi, 0x6000
        mov rcx, 0x5000
        xor al, al
        rep stosb
    }
}

func test_target_kernel_gdt() {
    asm {
        lgdt [gdt_ptr]
        mov ax, 0x10
        mov ds, ax
        mov es, ax
        mov ss, ax
    }
}

func test_target_kernel_idt() {
    asm {
        lidt [idt_ptr]
    }
}

// GDT and IDT for kernel target
asm {
    section .data
gdt_ptr_kernel:
    dw gdt_kernel_end - gdt_kernel_start - 1
    dq gdt_kernel_start
gdt_kernel_start:
    dq 0x0000000000000000
    dq 0x00CF9A000000FFFF
    dq 0x00CF92000000FFFF
gdt_kernel_end:

idt_ptr:
    dw idt_end - idt_start - 1
    dq idt_start
idt_start:
    times 256 dq 0
    times 256 dq 0
idt_end:
    section .text
}

