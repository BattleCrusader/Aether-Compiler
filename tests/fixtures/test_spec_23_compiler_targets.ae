// ── Target: binary ────────────────────────────────────────────────────────
// ELF64 — Userland binary at 0x2000000

@entry(0x2000000)
func test_target_binary_main(args: [][]byte): int {
    return 0
}

func test_target_binary_userland() {
    // Userland binary can use syscalls
    asm {
        mov rax, 0x2000004  ; write
        mov rdi, 1
        lea rsi, [rel .msg]
        mov rdx, 6
        syscall
    .msg:
        db "hello", 10
    }
}

// ── Target: boot ──────────────────────────────────────────────────────────
// Flat binary — Boot sector (stage1/stage2)

@layout(start=0x7C00, max=512, file="boot.bin")
func test_target_boot_sector() {
    asm {
        [org 0x7C00]
        xor ax, ax
        mov ds, ax
        mov es, ax
        mov ss, ax
        mov sp, 0x7C00
        mov si, msg
        call print
        hlt
    print:
        lodsb
        or al, al
        jz .done
        mov ah, 0x0E
        int 0x10
        jmp print
    .done:
        ret
    msg: db "Aether Boot", 0
    times 510-($-$$) db 0
    dw 0xAA55
    }
}

@layout(start=0x7E00, max=16384, file="stage2.bin")
func test_target_stage2() {
    asm {
        [org 0x7E00]
        mov ax, 0x0003
        int 0x10
        mov si, msg
        call print
        ; Load kernel
        mov ah, 0x42
        mov si, dap
        int 0x13
        jmp 0x100000
    print:
        lodsb
        or al, al
        jz .done
        mov ah, 0x0E
        int 0x10
        jmp print
    .done:
        ret
    msg: db "Loading kernel...", 0
    dap:
        db 0x10
        db 0
        dw 64
        dw 0x0000
        dw 0x1000
        dd 2
        dd 0
    }
}

// ── Target: asm-x86_64 ────────────────────────────────────────────────────
// NASM text — x86_64 assembly listing

func test_target_asm_x86_64() {
    asm {
        ; x86_64 specific instructions
        mov rax, 42
        add rax, 10
        sub rax, 5
        mul rbx
        div rcx
        push rax
        pop rbx
        ret
    }
}

