}

@layout(start=0x7C00, max=512, file="test.bin")
func test_attr_layout() {
    asm {
        times 510-($-$$) db 0
        dw 0xAA55
    }
}

@kernel_layout
func test_attr_kernel_layout() {
    asm {
        nop
    }
}

@export
func test_attr_export(): u64 {
    return 1
}

@module_abi(version=1)
module test_abi_module {
    @export func init(): int {
        return 0
    }
}

// ── Target-Specific Code Paths ────────────────────────────────────────────

func test_target_specific_code(target: u64): u64 {
    if target == 0 {
        // host target
        return 1
    } elif target == 1 {
        // x86_64-freestanding
        return 2
    } elif target == 2 {
        // kernel
        return 3
    } elif target == 3 {
        // module
        return 4
    } elif target == 4 {
        // binary
        return 5
    } elif target == 5 {
        // boot
        return 6
    }
    return 0
}

// ── Target Configuration ──────────────────────────────────────────────────

const TARGET_HOST: u64 = 0
const TARGET_FREESTANDING: u64 = 1
const TARGET_KERNEL: u64 = 2
const TARGET_MODULE: u64 = 3
const TARGET_BINARY: u64 = 4
const TARGET_BOOT: u64 = 5
const TARGET_ASM_X86: u64 = 6
const TARGET_ASM_ARM: u64 = 7
const TARGET_ASM_RISCV: u64 = 8
const TARGET_UNIVERSAL: u64 = 9
const TARGET_UNIVERSAL_ALL: u64 = 10
const TARGET_WASM: u64 = 11

func test_target_config(target_id: u64): bool {
    if target_id == TARGET_HOST { return true }
    if target_id == TARGET_FREESTANDING { return true }
    if target_id == TARGET_KERNEL { return true }
    if target_id == TARGET_MODULE { return true }
    if target_id == TARGET_BINARY { return true }
    if target_id == TARGET_BOOT { return true }
    if target_id == TARGET_ASM_X86 { return true }
    if target_id == TARGET_ASM_ARM { return true }
    if target_id == TARGET_ASM_RISCV { return true }
    if target_id == TARGET_UNIVERSAL { return true }
    if target_id == TARGET_UNIVERSAL_ALL { return true }
    if target_id == TARGET_WASM { return true }
    return false
}

// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run all target tests
    let mut result: u64 = 0

    result += test_target_host_entry()
    result += test_target_host_return()
    result += test_target_binary_main([])
    result += test_target_wasm32()
    result += test_attr_export()
    result += test_target_specific_code(TARGET_HOST)
    result += test_target_specific_code(TARGET_FREESTANDING)
    result += test_target_specific_code(TARGET_KERNEL)
    result += test_target_specific_code(TARGET_MODULE)
    result += test_target_specific_code(TARGET_BINARY)
    result += test_target_specific_code(TARGET_BOOT)

    if test_target_config(TARGET_HOST) { result += 1 }
    if test_target_config(TARGET_FREESTANDING) { result += 1 }
    if test_target_config(TARGET_KERNEL) { result += 1 }
    if test_target_config(TARGET_MODULE) { result += 1 }
    if test_target_config(TARGET_BINARY) { result += 1 }
    if test_target_config(TARGET_BOOT) { result += 1 }
    if test_target_config(TARGET_ASM_X86) { result += 1 }
    if test_target_config(TARGET_ASM_ARM) { result += 1 }
    if test_target_config(TARGET_ASM_RISCV) { result += 1 }
    if test_target_config(TARGET_UNIVERSAL) { result += 1 }
    if test_target_config(TARGET_UNIVERSAL_ALL) { result += 1 }
    if test_target_config(TARGET_WASM) { result += 1 }

    return result
}
