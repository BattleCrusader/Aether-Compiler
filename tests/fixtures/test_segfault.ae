// test_segfault.ae — catch a segfault with try/catch
import "std/test"

@test
func main(): void {
    let mut result: u64 = 0

    try {
        // Trigger SIGSEGV by dereferencing null via inline asm
        asm {
            mov rax, 0
            mov rax, [rax]
        }
        result = 1
    } catch _ {
        result = 42
    }

    assertEquals(42, result, "test_segfault.ae")
}
