// test_params.ae — function calls: multiple params, recursion
import "std/test"

func add(a: u64, b: u64): u64 {
    return a + b
}

func factorial(n: u64): u64 {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

@test
func main(): void {
    let r1 = add(10, 20)        // 30
    let r2 = factorial(5)       // 120
    assertEquals(150, r1 + r2, "test_params.ae")
}