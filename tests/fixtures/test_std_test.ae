// test_std_test.ae — verify std/test.ae works
// Tests both passing and failing assertions, then returns the failure count.
import "std/test"

@test
func main(): void {
    // Passing assertions
    assertEquals(5, 2 + 3)
    assertEquals(5, 2 + 3, "2 + 3 should be 5")

    let actualValue: bool = true
    assertTrue(actualValue)
    assertTrue(true, "true should be true")

    // Failing assertions (should be counted, not cause exit)
    assertEquals(3, 2 + 3) // Failure: expected 5, got 3
    assertEquals(3, 2 + 3, "2 + 3 should be 5") // Failure: 2 + 3 should be 5
    assertTrue(actualValue == false) // Failure: expected true, got false
    assertTrue(actualValue == false, "actualValue should be true") // Failure: actualValue should be true

    assertEquals(4, __test_failures, "test_std_test.ae")
}
