// test_trycatch_nested.ae — nested try/catch
import "std/test"

func inner_throw(): u64 throws {
    throw 1
    return 0
}

@test
func main(): void {
    let mut result: u64 = 0

    try {
        try {
            result = inner_throw()
        } catch _ {
            result = 42
        }
    } catch _ {
        result = 20
    }

    assertEquals(42, result, "test_trycatch_nested.ae")
}
