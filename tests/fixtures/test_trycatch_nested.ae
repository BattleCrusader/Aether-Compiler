// test_trycatch_nested.ae — nested try/catch
func inner_throw(): u64 throws {
    throw 1
    return 0
}

@test(expect=42)
func main(): u64 {
    let mut result: u64 = 0

    try {
        try {
            result = inner_throw()
        } catch _ {
            result = 42
        }
    } catch _ {
        result = 20
    }

    return result
}
