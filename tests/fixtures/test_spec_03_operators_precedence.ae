// test_spec_03_operators_precedence.ae — Section 3.5: Operator Precedence
// Tests: 14 levels of precedence

import "std/test"

@test
func main(): void {
    // Level 3 (* / %) before Level 4 (+ -)
    let prec_mul_add: u64 = 2 + 3 * 4   // 2 + 12 = 14 (not 20)
    let prec_div_sub: u64 = 10 - 6 / 2  // 10 - 3 = 7 (not 2)

    // Level 5 (<< >>) before Level 4 (+ -)
    let prec_shift: u64 = 1 + 2 << 1    // 1 + (2 << 1) = 1 + 4 = 5

    // Level 6 (&) before Level 8 (|)
    let prec_and_or: u64 = 0b1100 & 0b1010 | 0b0001
    // (0b1100 & 0b1010) | 0b0001 = 0b1000 | 0b0001 = 0b1001 = 9

    // Level 10 (== != < >) before Level 11 (&&)
    let prec_cmp_and: bool = 1 < 2 && 3 > 1  // true && true = true

    // Level 11 (&&) before Level 12 (||)
    let prec_and_or_logical: bool = true || false && false
    // true || (false && false) = true || false = true

    // Level 13 (=) is lowest among operators (right-associative)
    let mut a: u64 = 0
    let mut b: u64 = 0
    let mut c: u64 = 0
    a = b = c = 42  // right-associative: a = (b = (c = 42))

    // Parentheses override precedence
    let parens: u64 = (2 + 3) * 4  // 5 * 4 = 20

    // Complex precedence expression
    let complex: u64 = 1 + 2 * 3 - 8 / 4 + (1 << 2)
    // 1 + 6 - 2 + 4 = 9

    // Verify with assertions
    assertEquals(14, prec_mul_add, "2 + 3 * 4 should be 14 (not 20)")
    assertEquals(7, prec_div_sub, "10 - 6 / 2 should be 7 (not 2)")
    assertEquals(5, prec_shift, "1 + 2 << 1 should be 5")
    assertEquals(9, prec_and_or, "0b1100 & 0b1010 | 0b0001 should be 9")
    assertTrue(prec_cmp_and, "1 < 2 && 3 > 1 should be true")
    assertTrue(prec_and_or_logical, "true || false && false should be true")
    assertEquals(42, a, "a should be 42 after right-associative assignment")
    assertEquals(42, b, "b should be 42 after right-associative assignment")
    assertEquals(42, c, "c should be 42 after right-associative assignment")
    assertEquals(20, parens, "(2 + 3) * 4 should be 20")
    assertEquals(9, complex, "1 + 2*3 - 8/4 + (1<<2) should be 9")
}
