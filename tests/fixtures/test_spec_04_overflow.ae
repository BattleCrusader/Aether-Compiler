// test_spec_04_overflow.ae — Section 4.1: Integer Overflow Semantics
// Tests: wrapping arithmetic (two's complement for signed, modulo 2^N for unsigned)

import "std/test"

@test
func main(): void {
    // Unsigned wrapping: u8 max + 1 wraps to 0
    let u8_max: u8 = 255
    let u8_wrap: u8 = u8_max + 1  // wraps to 0

    // Unsigned wrapping: u8 0 - 1 wraps to 255
    let u8_zero: u8 = 0
    let u8_wrap2: u8 = u8_zero - 1  // wraps to 255

    // Unsigned wrapping: u16 max + 1
    let u16_max: u16 = 65535
    let u16_wrap: u16 = u16_max + 1  // wraps to 0

    // Unsigned wrapping: u32 max + 1
    let u32_max: u32 = 4294967295
    let u32_wrap: u32 = u32_max + 1  // wraps to 0

    // Unsigned wrapping: multiplication overflow
    let u8_mul: u8 = 200 * 2  // 400 % 256 = 144

    // Signed wrapping: i8 max + 1 wraps to -128
    let i8_max: i8 = 127
    let i8_wrap: i8 = i8_max + 1  // wraps to -128

    // Signed wrapping: i8 min - 1 wraps to 127
    let i8_min: i8 = -128
    let i8_wrap2: i8 = i8_min - 1  // wraps to 127

    // Signed wrapping: negative * negative = positive
    let i8_neg_mul: i8 = -100 * -2  // 200 wraps to -56

    // Verify wrapping behavior
    assertEquals(0, u8_wrap as u64, "u8 255 + 1 should wrap to 0")
    assertEquals(255, u8_wrap2 as u64, "u8 0 - 1 should wrap to 255")
    assertEquals(0, u16_wrap as u64, "u16 65535 + 1 should wrap to 0")
    assertEquals(0, u32_wrap as u64, "u32 max + 1 should wrap to 0")
    assertEquals(144, u8_mul as u64, "u8 200 * 2 should wrap to 144")
    assertEquals(-128, i8_wrap as i64, "i8 127 + 1 should wrap to -128")
    assertEquals(127, i8_wrap2 as i64, "i8 -128 - 1 should wrap to 127")
}
