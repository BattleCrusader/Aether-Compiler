// test_trycatch_finally_throw.ae — throw with finally
func do_throw(): u64 throws {
    throw 99
    return 0
}

@test(expect=42)
func main(): u64 {
    let mut result: u64 = 0

    try {
        result = do_throw()
    } catch Error {
        result = 42
    } finally {
        // finally ran
    }

    return result
}
