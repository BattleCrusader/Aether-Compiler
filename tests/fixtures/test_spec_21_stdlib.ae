// test_spec_21_stdlib.ae — Comprehensive tests for SPECIFICATION.md §21
// Standard Library: std/io, std/mem, std/str, std/math, std/collections,
// std/fs, std/serial, std/elf, std/test, std/asm, std/arch
//
// NOTE: Uses only syntax confirmed supported by the parser/codegen.
// No struct literals, no void*, no tuple returns.

import "std/io"
import "std/mem"
import "std/math"
import "std/str"
import "std/collections"
import "std/fs"
import "std/serial"
import "std/elf"
import "std/test"
import "std/asm"
