// ── Built-in Functions ────────────────────────────────────────────────────
// sizeof, alignof, offsetof, typeName, panic

struct TestStruct {
    a: u64
    b: u64
    c: u64
}

func test_sizeof_u64(): u64 {
    return sizeof(u64)
}

func test_sizeof_u8(): u64 {
    return sizeof(u8)
}

func test_sizeof_bool(): u64 {
    return sizeof(bool)
}

func test_sizeof_struct(): u64 {
    return sizeof(TestStruct)
}

func test_alignof_u64(): u64 {
    return alignof(u64)
}

func test_alignof_u8(): u64 {
    return alignof(u8)
}

func test_typeName_u64(): string {
    return typeName(u64)
}

func test_typeName_bool(): string {
    return typeName(bool)
}

// ── Main entry point ──────────────────────────────────────────────────────

func main(): u64 {
    // Run all stdlib tests
    let mut failures: u64 = 0

    // I/O tests
    test_io_print()
    test_io_println()
    test_io_print_line()
    test_io_print_error()
    test_io_print_hex()
    test_io_print_decimal()

    // Memory tests
    failures += 1 - test_mem_alloc()
    failures += 1 - test_mem_alloc_zero()
    failures += 1 - test_mem_alloc_large()
    failures += 1 - test_mem_alloc_multiple()
    test_mem_copy()

    // String tests
    let s: string = test_str_concat()
    let s2: string = test_str_concat_multiple()
    let s3: string = test_str_concat_empty()
    let s4: string = test_str_concat_numeric()
    let c: byte = test_str_index()
    let c2: byte = test_str_index_middle()
    let c3: byte = test_str_index_last()
    let empty: string = test_str_empty()
    let interp: string = test_str_interpolation()
    let interp_n: string = test_str_interpolation_numeric()
    let interp_expr: string = test_str_interpolation_expression()

    // Math tests
    if test_math_abs_i64() != 42 { failures += 1 }
    if test_math_abs_positive() != 42 { failures += 1 }
    if test_math_abs_zero() != 0 { failures += 1 }
    if test_math_min() != 10 { failures += 1 }
    if test_math_min_reverse() != 10 { failures += 1 }
    if test_math_min_equal() != 10 { failures += 1 }
    if test_math_max() != 20 { failures += 1 }
    if test_math_max_reverse() != 20 { failures += 1 }
    if test_math_max_equal() != 20 { failures += 1 }

    // Collections tests
    if test_collections_array_basic() != 15 { failures += 1 }
    if test_collections_array_index() != 30 { failures += 1 }
    if test_collections_array_length() != 5 { failures += 1 }
    if test_collections_array_iterate() != 15 { failures += 1 }
    if test_collections_array_iterate_index() != 60 { failures += 1 }

    // FS tests
    test_fs_path_operations()
    test_fs_file_open()
    test_fs_file_not_found()
    test_fs_directory_ops()

    // Serial tests
    test_serial_init()
    test_serial_putc()
    test_serial_puts()
    test_serial_puthex()
    test_serial_newline()

    // ELF tests
    if !test_elf_magic() { failures += 1 }
    if !test_elf_class() { failures += 1 }
    if !test_elf_endian() { failures += 1 }
    if !test_elf_type_exec() { failures += 1 }
    if !test_elf_type_dynamic() { failures += 1 }

    // Arch tests
    test_arch_detect()
    test_arch_is_x86()
    test_arch_is_arm()
    test_arch_is_riscv()
    test_arch_page_size()
    test_arch_cache_line()

    // Built-in tests
    if test_sizeof_u64() != 8 { failures += 1 }
    if test_sizeof_u8() != 1 { failures += 1 }
    if test_sizeof_bool() != 1 { failures += 1 }
    if test_alignof_u64() != 8 { failures += 1 }
    if test_alignof_u8() != 1 { failures += 1 }

    return failures
}
