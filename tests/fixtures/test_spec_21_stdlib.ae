// ── 21.5 std/collections — Collections ────────────────────────────────────
// Array, HashMap, Set, List, Queue, Stack, Deque

func test_collections_array_basic(): u64 {
    let arr: [u64] = [1, 2, 3, 4, 5]
    return arr[0] + arr[1] + arr[2] + arr[3] + arr[4]
}

func test_collections_array_empty(): u64 {
    let arr: [u64] = []
    return 0
}

func test_collections_array_index(): u64 {
    let arr: [u64] = [10, 20, 30, 40, 50]
    return arr[2]
}

func test_collections_array_length(): u64 {
    let arr: [u64] = [1, 2, 3, 4, 5]
    return #arr
}

func test_collections_array_mutate() {
    let mut arr: [u64] = [1, 2, 3]
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300
}

func test_collections_array_iterate(): u64 {
    let arr: [u64] = [1, 2, 3, 4, 5]
    let mut sum: u64 = 0
    for val in arr {
        sum += val
    }
    return sum
}

func test_collections_array_iterate_index(): u64 {
    let arr: [u64] = [10, 20, 30]
    let mut sum: u64 = 0
    for i, val in arr {
        sum += val
    }
    return sum
}

func test_collections_array_of_u8(): byte {
    let arr: [byte] = [72, 101, 108, 108, 111]
    return arr[0]
}

func test_collections_array_of_bool(): bool {
    let arr: [bool] = [true, false, true]
    return arr[0]
}

// ── 21.6 std/fs — Filesystem Operations ───────────────────────────────────
// File, Path, Directory

func test_fs_path_operations(): u64 {
    // Path operations via syscalls
    return 1
}

func test_fs_file_open(): int {
    let fd: int = fs_open("/tmp/test.txt")
    if fd >= 0 {
        fs_close(fd)
    }
    return fd
}

func test_fs_file_not_found(): int {
    let fd: int = fs_open("/nonexistent/file.txt")
    return fd  // Should return negative
}

func test_fs_directory_ops(): int {
    let result: int = fs_mkdir("/tmp/testdir")
    if result >= 0 {
        fs_unlink("/tmp/testdir")
    }
    return result
}

