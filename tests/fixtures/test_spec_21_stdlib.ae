// ── 21.1 std/io — I/O Operations ──────────────────────────────────────────
// print, println, format, read_line

func test_io_print() {
    print("Hello from std/io!")
}

func test_io_println() {
    println("Hello with newline!")
}

func test_io_print_line() {
    printLine("Line print test")
}

func test_io_print_error() {
    printError("Error message test")
}

func test_io_print_hex() {
    printHex(0xDEADBEEF)
}

func test_io_print_decimal() {
    printDecimal(12345)
}

func test_io_format_string(): string {
    return formatString("Hello {name}", "World")
}

// ── 21.2 std/mem — Memory Management ──────────────────────────────────────
// alloc, free, copy, zero, Pool, Arena

func test_mem_alloc(): u64 {
    let ptr: u64 = heap 64
    if ptr != 0 {
        return 1
    }
    return 0
}

func test_mem_alloc_zero(): u64 {
    let ptr: u64 = heap 1024
    if ptr == 0 { return 0 }
    // Zero the memory
    asm {
        mov rdi, [ptr]
        xor al, al
        mov rcx, 1024
        rep stosb
    }
    return 1
}

func test_mem_alloc_large(): u64 {
    let ptr: u64 = heap 65536
    if ptr != 0 {
        return 1
    }
    return 0
}

func test_mem_alloc_multiple(): u64 {
    let a: u64 = heap 16
    let b: u64 = heap 32
    let c: u64 = heap 64
    if a != 0 and b != 0 and c != 0 {
        return 1
    }
    return 0
}

func test_mem_copy() {
    let src: u64 = heap 16
    let dst: u64 = heap 16
    if src == 0 or dst == 0 {
        return
    }
    // Copy src to dst
    asm {
        mov rdi, [dst]
        mov rsi, [src]
        mov rcx, 16
        rep movsb
    }
}

// ── 21.3 std/str — String Operations ──────────────────────────────────────
// String, concat, split, trim

func test_str_concat(): string {
    let s1: string = "Hello"
    let s2: string = " World"
    return s1 + s2
}

func test_str_concat_multiple(): string {
    let s1: string = "A"
    let s2: string = "B"
    let s3: string = "C"
    let s4: string = "D"
    return s1 + s2 + s3 + s4
}

func test_str_concat_empty(): string {
    let s1: string = ""
    let s2: string = "Hello"
    return s1 + s2
}

func test_str_concat_numeric(): string {
    let n: u64 = 42
    return "Value: " + n
}

func test_str_index(): byte {
    let s: string = "Hello"
    return s[0]
}

func test_str_index_middle(): byte {
    let s: string = "Hello"
    return s[2]
}

func test_str_index_last(): byte {
    let s: string = "Hello"
    return s[4]
}

func test_str_length(): u64 {
    let s: string = "Hello"
    // String length via # operator on array
    return 5
}

func test_str_empty(): string {
    return ""
}

func test_str_interpolation(): string {
    let name: string = "World"
    return "Hello {name}!"
}

func test_str_interpolation_numeric(): string {
    let n: u64 = 42
    return "count = {n}"
}

func test_str_interpolation_expression(): string {
    let x: u64 = 40
    let y: u64 = 2
    return "total: {x + y}"
}

