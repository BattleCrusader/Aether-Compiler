// test_errors.ae — custom error types with enum variants and discriminant matching
import "std/test"

enum MyError {
    NotFound
    PermissionDenied
    Timeout
}

func do_fail(): u64 throws {
    throw MyError::NotFound
    return 0
}

@test
func main(): void {
    let mut result: u64 = 0

    try {
        result = do_fail()
    } catch Timeout {
        result = 10
    } catch NotFound {
        result = 42
    } catch PermissionDenied {
        result = 20
    }

    assertEquals(42, result, "test_errors.ae")
}
