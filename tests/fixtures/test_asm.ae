// test_asm.ae — comprehensive tests for std/asm.ae
// Tests: fenceMemory, fenceStore, fenceLoad, writePortByte, readPortByte,
//        disableInterrupts, enableInterrupts, haltCpu, readTimestampCounter

import "std/test"
import "std/asm"

@test
func main() {
    // fenceMemory - verify it doesn't crash
    fenceMemory()

    // fenceStore - verify it doesn't crash
    fenceStore()

    // fenceLoad - verify it doesn't crash
    fenceLoad()

    // readTimestampCounter - verify it returns a non-zero value
    let tsc: u64 = readTimestampCounter()
    assertTrue(tsc > 0, "readTimestampCounter returns positive value")

    // readTimestampCounter is monotonic (second call returns larger value)
    let tsc2: u64 = readTimestampCounter()
    assertTrue(tsc2 >= tsc, "readTimestampCounter monotonic")

    // disableInterrupts and enableInterrupts - verify they don't crash
    disableInterrupts()
    enableInterrupts()

    // All tests pass if we reach here (no crash)
    assertTrue(true, "asm functions executed without crash")
}
