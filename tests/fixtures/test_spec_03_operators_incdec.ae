// test_spec_03_operators_incdec.ae — Section 3.4: Prefix/Postfix Increment/Decrement
// Tests: ++x, x++, --x, x--

import "std/test"

@test
func main(): void {
    let mut a: u64 = 5

    // Prefix increment: returns new value
    let pre_inc = ++a   // a=6, pre_inc=6

    // Postfix increment: returns old value
    let post_inc = a++  // a=7, post_inc=6

    // Prefix decrement: returns new value
    let pre_dec = --a   // a=6, pre_dec=6

    // Postfix decrement: returns old value
    let post_dec = a--  // a=5, post_dec=6

    // Chain of increments
    let mut b: u64 = 0
    ++b
    ++b
    ++b               // b = 3
    b++               // b = 4, returns 3
    b++               // b = 5, returns 4

    // Decrement chain
    let mut c: u64 = 10
    --c              // c = 9
    c--              // c = 8, returns 9
    --c              // c = 7

    // Verify with assertions
    assertEquals(5, a, "final a should be 5 after post_dec")
    assertEquals(6, pre_inc, "prefix ++ should return new value (6)")
    assertEquals(6, post_inc, "postfix ++ should return old value (6)")
    assertEquals(6, pre_dec, "prefix -- should return new value (6)")
    assertEquals(6, post_dec, "postfix -- should return old value (6)")
    assertEquals(5, b, "b should be 5 after 3 pre-inc + 2 post-inc")
    assertEquals(7, c, "c should be 7 after --c, c--, --c")
}
