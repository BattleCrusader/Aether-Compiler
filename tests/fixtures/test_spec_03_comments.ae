// test_spec_03_comments.ae — Section 3.1: Comments
// Tests: line comments, block comments, nested block comments, doc comments

/* Block comment before function */

/* Nested /* block */ comments — this should compile */

/// Doc comment for this function
/// These are attached to the next declaration
@test(expect=0)
func main(): u64 {
    // Line comment inside function body
    let x: u64 = 42  // inline comment
    /* Block comment in middle of code */
    let y: u64 = 100
    /* Nested /* comment */ still works */
    let result = x + y
    return 0
}
