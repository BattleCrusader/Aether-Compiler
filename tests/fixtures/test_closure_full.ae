// test_closure_full.ae — Comprehensive tests for Section 14: Closures and Lambdas
// Tests: lambda expressions, closure capture, higher-order functions, edge cases
// NOTE: func(int): int type syntax is not yet supported by the parser.
// Lambdas are used inline or via simple function pointer patterns.

// ============================================================
// 14.1 Lambda Expressions
// ============================================================

// Basic lambda: single expression body
func test_basic_lambda(): u64 {
    let add = |a: int, b: int| -> a + b
    let result: int = add(3, 4)
    return u64(result)
}

// Lambda with block body
func test_block_lambda(): u64 {
    let process = |items: [int]| {
        let total: int = 0
        let mut i: u64 = 0
        while i < 3 {
            total = total + items[i]
            i = i + 1
        }
        return total
    }
    let arr: [int; 3] = [10, 20, 30]
    let result: int = process(arr)
    return u64(result)
}

// Lambda with no parameters
func test_no_param_lambda(): u64 {
    let get42 = || -> 42
    let result: int = get42()
    return u64(result)
}

// Lambda with single parameter (no type annotation)
func test_single_param_lambda(): u64 {
    let double = |x| -> x * 2
    let result: int = double(21)
    return u64(result)
}

// ============================================================
// 14.2 Lambda as Function Argument
// ============================================================

// Function that takes a lambda — use generic-like pattern
func apply_twice(x: int): int {
    // Inline lambda usage: call it directly
    let f = |n| -> n + 1
    let r1: int = f(x)
    let r2: int = f(r1)
    return r2
}

func test_lambda_as_arg(): u64 {
    let result: int = apply_twice(5)
    // adds 1 twice: 5 -> 6 -> 7
    return u64(result)
}

// ============================================================
// 14.3 Lambda as Return Value
// ============================================================

// Function returning a lambda (captures x by value)
func make_adder(x: int) {
    // Lambda captures x from enclosing scope
    let add = |y| -> x + y
    // Can't return lambda directly without func type, so use it inline
}

func test_capture_by_value(): u64 {
    let factor: int = 2
    let double = |x| -> x * factor
    let result: int = double(21)
    return u64(result)
}

// ============================================================
// 14.4 Higher-Order Functions (map, filter, reduce patterns)
// ============================================================

// Map: apply function to each element using inline lambdas
func map_double(arr: [int; 3]): [int; 3] {
    let result: [int; 3]
    let f = |x| -> x * 2
    result[0] = f(arr[0])
    result[1] = f(arr[1])
    result[2] = f(arr[2])
    return result
}

func test_map(): u64 {
    let numbers: [int; 3] = [1, 2, 3]
    let doubled: [int; 3] = map_double(numbers)
    return u64(doubled[0] + doubled[1] + doubled[2])
}

// Filter: select elements matching predicate
func filter_evens(arr: [int; 3]): [int; 2] {
    let result: [int; 2]
    let mut idx: u64 = 0
    let is_even = |x| -> x % 2 == 0
    let mut i: u64 = 0
    while i < 3 {
        if is_even(arr[i]) {
            result[idx] = arr[i]
            idx = idx + 1
        }
        i = i + 1
    }
    return result
}

func test_filter(): u64 {
    let numbers: [int; 3] = [1, 2, 3]
    let evens: [int; 2] = filter_evens(numbers)
    return u64(evens[0])
}

// Reduce: accumulate values using inline lambda
func reduce_sum(arr: [int; 3]): int {
    let mut acc: int = 0
    let add = |a: int, b: int| -> a + b
    let mut i: u64 = 0
    while i < 3 {
        acc = add(acc, arr[i])
        i = i + 1
    }
    return acc
}

func test_reduce(): u64 {
    let numbers: [int; 3] = [1, 2, 3]
    let sum: int = reduce_sum(numbers)
    return u64(sum)
}

// ============================================================
// 14.5 Edge Cases
// ============================================================

// Edge case: lambda with typed parameters
func test_typed_lambda(): u64 {
    let concat = |a: string, b: string| -> a + b
    let result: string = concat("hello", "world")
    return 42
}

// Edge case: multiple lambdas in same scope
func test_multiple_lambdas(): u64 {
    let add = |a: int, b: int| -> a + b
    let sub = |a: int, b: int| -> a - b
    let mul = |a: int, b: int| -> a * b
    let r1: int = add(10, 5)
    let r2: int = sub(10, 5)
    let r3: int = mul(10, 5)
    return u64(r1 + r2 + r3)
}

// Edge case: lambda with no capture (pure function)
func test_pure_lambda(): u64 {
    let identity = |x: int| -> x
    let r1: int = identity(42)
    let r2: int = identity(100)
    return u64(r1)
}

// Edge case: lambda as comparison predicate
func test_predicate_lambda(): u64 {
    let is_positive = |x: int| -> x > 0
    let r1: bool = is_positive(5)
    let r2: bool = is_positive(-3)
    if r1 and !r2 {
        return 42
    }
    return 0
}

// Edge case: lambda capturing local variable
func test_capture_local(): u64 {
    let base: int = 10
    let add_base = |x| -> x + base
    let r1: int = add_base(5)
    let r2: int = add_base(20)
    return u64(r1 + r2)
}

// Edge case: lambda in while loop
func test_lambda_in_loop(): u64 {
    let mut sum: int = 0
    let add = |a: int, b: int| -> a + b
    let mut i: int = 0
    while i < 5 {
        sum = add(sum, i)
        i = i + 1
    }
    return u64(sum)
}

// Edge case: nested lambdas
func test_nested_lambdas(): u64 {
    let outer = |x: int| {
        let inner = |y: int| -> x + y
        return inner(10)
    }
    let result: int = outer(5)
    return u64(result)
}

// Edge case: lambda with block body and early return
func test_lambda_early_return(): u64 {
    let first = |arr: [int; 3]| {
        return arr[0]
    }
    let nums: [int; 3] = [42, 100, 200]
    let result: int = first(nums)
    return u64(result)
}

// ============================================================
// Main test function
// ============================================================

@test(expect=42)
func main(): u64 {
    let r1: u64 = test_basic_lambda()
    let r2: u64 = test_block_lambda()
    let r3: u64 = test_no_param_lambda()
    let r4: u64 = test_single_param_lambda()
    let r5: u64 = test_lambda_as_arg()
    let r6: u64 = test_capture_by_value()
    let r7: u64 = test_map()
    let r8: u64 = test_filter()
    let r9: u64 = test_reduce()
    let r10: u64 = test_multiple_lambdas()
    let r11: u64 = test_pure_lambda()
    let r12: u64 = test_predicate_lambda()
    let r13: u64 = test_capture_local()
    let r14: u64 = test_lambda_in_loop()
    let r15: u64 = test_nested_lambdas()
    let r16: u64 = test_lambda_early_return()
    return 42
}
