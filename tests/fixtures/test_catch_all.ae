// test_catch_all.ae — catch-all with _
import "std/test"

func do_throw(): u64 throws {
    throw 99
    return 0
}

@test
func main(): void {
    let mut result: u64 = 0

    try {
        result = do_throw()
    } catch _ {
        result = 42
    }

    assertEquals(42, result, "test_catch_all.ae")
}
