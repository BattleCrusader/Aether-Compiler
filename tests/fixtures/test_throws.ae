// test_throws.ae — throws function return type and error propagation
import "std/test"

// throws function with return type
func divide(a: int, b: int): int throws {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

// throws function with void return
func validate(cond: bool) throws {
    if !cond {
        throw "validation failed"
    }
}

@test
func test_throws_compiles(): void {
    assertTrue(true, "throws function compiles")
}

@test
func test_throws_success(): void {
    let r: int = divide(10, 2)
    assertTrue(r == 5, "divide(10, 2) == 5")
}
