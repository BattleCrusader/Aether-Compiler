import "std/test"

func divide(a: int, b: int): int throws {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

@test
func test_throws_compiles(): void {
    assertTrue(true, "throws function compiles")
}

@test
func test_throws_success(): void {
    let r: int = divide(10, 2)
    assertTrue(r == 5, "divide(10, 2) == 5")
}
