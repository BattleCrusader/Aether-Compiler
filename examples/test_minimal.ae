// test_minimal.ae — minimal test, no stdlib
struct Token {
    kind: u64
    text: string
}

struct Lexer {
    input: string
    pos: u64
    tokens: [Token]
}

func lexerCreate(input: string): Lexer {
    let mut l: Lexer
    l.input = input
    l.pos = 0
    l.tokens = []
    return l
}

func lexerPeek(l: ref Lexer): byte {
    return l.input[l.pos]
}

func lexerAdvance(l: ref Lexer) {
    l.pos = l.pos + 1
}

func lexerTokenize(l: ref Lexer): [Token] {
    l.tokens = []
    while true {
        let c: byte = lexerPeek(l)
        if c == 0 { break }
        if c == 10 { lexerAdvance(l); continue }
        lexerAdvance(l)
    }
    return l.tokens
}

func main(): u64 {
    let input: string = "hello"
    let mut lexer: Lexer = lexerCreate(input)
    let tokens: [Token] = lexerTokenize(ref lexer)
    return 0
}
